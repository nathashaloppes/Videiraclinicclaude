# ============================================================
# VIDEIRA DENTAL CLINIC — Variáveis de ambiente
# Copie para .env e preencha com valores reais
# NUNCA commite o .env (já está no .gitignore)
# ============================================================

# ---- Banco de dados -----------------------------------------
# Em desenvolvimento local (WSL/Linux) use peer auth — deixe DATABASE_URL em branco.
# Em produção ou Docker, preencha:
DATABASE_URL=postgresql://USUARIO:SENHA@localhost:5432/videira_dental_production

# ---- Redis --------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---- Aplicação ----------------------------------------------
# Segredo Rails (gere com: rails secret)
SECRET_KEY_BASE=GERE_COM_rails_secret

# ---- Google OAuth 2.0 ---------------------------------------
# Obtenha em: console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=SEU_GOOGLE_CLIENT_SECRET

# ---- MercadoPago (Sandbox) ----------------------------------
# Obtenha em: mercadopago.com.br > Developers > Credenciais
MERCADOPAGO_ACCESS_TOKEN=TEST-SEU_ACCESS_TOKEN_AQUI
MERCADOPAGO_PUBLIC_KEY=TEST-SEU_PUBLIC_KEY_AQUI
# Segredo para validar assinatura do webhook (HMAC-SHA256)
MERCADOPAGO_WEBHOOK_SECRET=SEU_WEBHOOK_SECRET_AQUI

# ---- Configurações de negócio (opcionais — têm defaults) ----
# Antecedência mínima para cancelamento (em horas)
CANCELLATION_LEAD_HOURS=48
# Janela para pagamento do Pix expirar (em minutos)
PAYMENT_EXPIRY_MINUTES=30

# ---- Seeds --------------------------------------------------
# Senha do usuário owner criado pelo seed
OWNER_PASSWORD=TrocaEstaVirtudeMinima1!

# ---- Email (Action Mailer) ----------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=SEU_EMAIL@gmail.com
SMTP_PASSWORD=SEU_APP_PASSWORD
