<h2>Pagamento confirmado!</h2>

<p>Olá <%= @dentist.name %>,</p>

<p>Sua reserva foi confirmada com sucesso. Detalhes:</p>

<ul>
  <% @group.bookings.includes(:availability).each do |b| %>
    <li>
      <%= b.availability.label %> —
      <%= l(b.availability.date, format: :default) %>,
      <%= b.availability.starts_at.strftime("%H:%M") %>–<%= b.availability.ends_at.strftime("%H:%M") %>
    </li>
  <% end %>
</ul>

<p><strong>Total pago:</strong> R$ <%= "%.2f" % (@group.payment.amount_cents / 100.0) %></p>

<p>Até lá!<br>Equipe Videira Dental</p>
