<% content_for :title, "Videira Dental — Agende sua sala" %>

<div class="max-w-5xl mx-auto">
  <%# Hero %>
  <div class="text-center py-12">
    <h1 class="text-4xl font-bold text-gray-900">Reserve sua sala odontológica</h1>
    <p class="mt-3 text-lg text-gray-500">Escolha o serviço, selecione o horário e pague com Pix em segundos.</p>
  </div>

  <%# Filtro de data %>
  <div class="flex items-center gap-3 mb-6">
    <label class="text-sm font-medium text-gray-700">Data:</label>
    <%= form_with url: root_path, method: :get, data: { turbo: false } do |f| %>
      <%= f.date_field :date, value: @date, class: "border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500",
            onchange: "this.form.submit()" %>
    <% end %>
    <span class="text-sm text-gray-500"><%= l(@date, format: :long) %></span>
  </div>

  <%# Carrinho flutuante %>
  <%= turbo_frame_tag "cart-summary" do %>
    <%= render "shared/cart_summary" %>
  <% end %>

  <%# Slots do dia %>
  <% if @availabilities.empty? %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-lg">Nenhum horário disponível para esta data.</p>
      <p class="text-sm mt-2">Tente outra data ou verifique novamente mais tarde.</p>
    </div>
  <% else %>
    <div id="availability-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @availabilities.each do |av| %>
        <%= render "shared/slot_card", availability: av %>
      <% end %>
    </div>
  <% end %>
</div>
