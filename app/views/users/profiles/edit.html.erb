<% content_for :title, "Editar perfil" %>

<%= render "shared/back_button", path: perfil_path %>

<h1 class="text-2xl font-medium mb-6" style="color: #3E2723">Editar perfil</h1>

<%= render "shared/form_errors", object: @user if @user.errors.any? %>

<%= form_with model: @user, url: perfil_path, method: :patch, multipart: true,
      class: "flex flex-col gap-3" do |f| %>

  <div class="flex justify-center mb-2">
    <%= render "shared/avatar", user: @user, size: "lg" %>
  </div>

  <div>
    <%= f.label :avatar, "Foto de perfil", class: "block text-xs font-medium mb-1 px-1", style: "color: #8D6E63" %>
    <div class="bg-white rounded-2xl shadow-sm px-4 py-1">
      <%= f.file_field :avatar, accept: "image/*",
            class: "w-full bg-transparent border-none outline-none py-3 text-sm",
            style: "color: #3E2723" %>
    </div>
  </div>

  <div>
    <%= f.label :name, "Nome completo", class: "block text-xs font-medium mb-1 px-1", style: "color: #8D6E63" %>
    <div class="bg-white rounded-2xl shadow-sm px-4 py-1">
      <%= f.text_field :name,
            placeholder: "Nome completo",
            class: "w-full bg-transparent border-none outline-none py-3 text-sm",
            style: "color: #3E2723" %>
    </div>
  </div>

  <div>
    <%= f.label :phone, "Telefone", class: "block text-xs font-medium mb-1 px-1", style: "color: #8D6E63" %>
    <div class="bg-white rounded-2xl shadow-sm px-4 py-1">
      <%= f.telephone_field :phone, autocomplete: "tel",
            placeholder: "(11) 91234-5678",
            class: "w-full bg-transparent border-none outline-none py-3 text-sm",
            style: "color: #3E2723",
            data: { controller: "input-mask", "input-mask-pattern-value": "phone" } %>
    </div>
  </div>

  <div>
    <%= f.label :cpf, "CPF", class: "block text-xs font-medium mb-1 px-1", style: "color: #8D6E63" %>
    <div class="bg-white rounded-2xl shadow-sm px-4 py-1">
      <%= f.text_field :cpf, inputmode: "numeric",
            placeholder: "000.000.000-00",
            class: "w-full bg-transparent border-none outline-none py-3 text-sm",
            style: "color: #3E2723",
            data: { controller: "input-mask", "input-mask-pattern-value": "cpf" } %>
    </div>
  </div>

  <div>
    <%= f.label :birth_date, "Data de nascimento", class: "block text-xs font-medium mb-1 px-1", style: "color: #8D6E63" %>
    <div class="bg-white rounded-2xl shadow-sm px-4 py-1">
      <%= f.date_field :birth_date,
            class: "w-full bg-transparent border-none outline-none py-3 text-sm",
            style: "color: #3E2723" %>
    </div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= link_to "Cancelar", perfil_path, class: "btn-outline flex-1 text-center" %>
    <%= f.submit "Salvar alterações", class: "btn-primary flex-1 cursor-pointer" %>
  </div>

<% end %>
