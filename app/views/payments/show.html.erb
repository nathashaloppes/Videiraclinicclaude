<% content_for :title, "Pagamento via Pix" %>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Pagamento via Pix</h1>

  <%# Turbo Stream subscribed to live updates %>
  <%= turbo_stream_from "payment_#{@payment.id}" %>

  <%# Resumo dos horários %>
  <div class="bg-white rounded-xl border border-gray-200 p-5 mb-4">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Resumo</h2>
    <% @payment.booking_group.bookings.includes(:availability => :service).each do |b| %>
      <div class="flex justify-between text-sm py-1">
        <span class="text-gray-700">
          <%= b.availability.service.name %> ·
          <%= l(b.availability.date, format: :default) %>
          <%= b.availability.starts_at.strftime("%H:%M") %>
        </span>
        <span class="font-medium">R$ <%= money(b.price_cents) %></span>
      </div>
    <% end %>
    <div class="border-t mt-3 pt-3 flex justify-between font-bold text-base">
      <span>Total</span>
      <span class="text-blue-700">R$ <%= money(@payment.amount_cents) %></span>
    </div>
  </div>

  <%# Status dinâmico (trocado pelo Turbo Stream) %>
  <div id="payment_status">
    <% if @payment.paid? %>
      <%= render "payments/paid", payment: @payment %>
    <% elsif @payment.expired? || @payment.cancelled? %>
      <%= render "payments/expired", payment: @payment %>
    <% else %>
      <%= render "payments/pending", payment: @payment %>
    <% end %>
  </div>
</div>
