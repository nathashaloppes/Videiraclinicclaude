<% content_for :title, "Pagamento via Pix" %>

<%= render "shared/back_button", path: reservas_path %>

<h1 class="text-2xl font-semibold mb-2 text-vdc-primary">Pagamento via Pix</h1>

<%= turbo_stream_from "payment_#{@payment.id}" %>

<div class="card-md mb-4">
  <p class="text-xs font-medium mb-3 text-vdc-secondary">Resumo do pedido</p>
  <% @payment.booking_group.bookings.includes(:availability).each do |b| %>
    <div class="flex justify-between text-sm py-1">
      <span class="text-vdc-foreground">
        <%= b.availability.label %> ·
        <%= l(b.availability.date, format: :default) %>
        <%= b.availability.starts_at.strftime("%H:%M") %>
      </span>
      <span class="font-medium text-vdc-primary">R$ <%= money(b.price_cents) %></span>
    </div>
  <% end %>
  <div class="border-t mt-3 pt-3 flex justify-between font-semibold" style="border-color: #E0E0E0">
    <span class="text-vdc-foreground">Total</span>
    <span class="text-xl font-bold text-vdc-primary">R$ <%= money(@payment.amount_cents) %></span>
  </div>
</div>

<turbo-frame id="payment_status">
  <% if @payment.paid? %>
    <%= render "payments/paid", payment: @payment %>
  <% elsif @payment.expired? || @payment.cancelled? %>
    <%= render "payments/expired", payment: @payment %>
  <% else %>
    <%= render "payments/pending", payment: @payment %>
  <% end %>
</turbo-frame>
