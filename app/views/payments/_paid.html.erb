<div class="card-sm border p-8 text-center" style="border-color: #E0E0E0">
  <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 badge-success">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="2.5" style="color: #388E3C">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
    </svg>
  </div>
  <h2 class="text-2xl font-medium mb-2" style="color: #388E3C">Pagamento confirmado!</h2>
  <p class="text-sm mb-1 text-vdc-secondary">
    Pago em <%= l(payment.paid_at, format: :default) rescue "agora" %>
  </p>
  <p class="text-sm mb-6 text-vdc-secondary">Sua reserva está confirmada. Até lá!</p>
  <%= link_to "Ver minhas reservas →", reservas_path,
        class: "inline-block px-6 py-3 rounded-full text-white text-sm font-medium",
        style: "background-color: #388E3C" %>
</div>
