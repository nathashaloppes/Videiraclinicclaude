<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Videira Dental" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <nav class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
      <%= link_to "Videira Dental", root_path, class: "text-xl font-bold text-blue-700" %>
      <div class="flex gap-4 items-center">
        <% if user_signed_in? %>
          <span class="text-sm text-gray-600"><%= current_user.name %></span>
          <% if current_user.owner? || current_user.dentist? %>
            <%= link_to "Admin", admin_root_path, class: "text-sm text-blue-600 hover:underline" %>
          <% end %>
          <%= button_to "Sair", destroy_user_session_path, method: :delete,
                class: "text-sm text-gray-500 hover:text-red-600" %>
        <% else %>
          <%= link_to "Entrar", new_user_session_path, class: "text-sm text-blue-600 hover:underline" %>
          <%= link_to "Cadastro", new_user_registration_path, class: "text-sm font-semibold text-blue-700 hover:underline" %>
        <% end %>
      </div>
    </nav>

    <% if notice.present? %>
      <div class="bg-green-50 border border-green-200 text-green-800 px-6 py-3 text-sm">
        <%= notice %>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="bg-red-50 border border-red-200 text-red-800 px-6 py-3 text-sm">
        <%= alert %>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-6 py-8">
      <%= yield %>
    </main>
  </body>
</html>
