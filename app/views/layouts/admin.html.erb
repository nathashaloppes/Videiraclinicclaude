<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>Admin — <%= content_for(:title) || "Videira Dental" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-100 text-gray-900 antialiased">
    <div class="flex h-screen">
      <aside class="w-64 bg-white border-r border-gray-200 flex flex-col">
        <div class="px-6 py-5 border-b">
          <%= link_to "Videira Dental", admin_root_path, class: "text-lg font-bold text-blue-700" %>
          <span class="block text-xs text-gray-500 mt-1">Painel Administrativo</span>
        </div>
        <nav class="flex-1 px-4 py-6 space-y-1 text-sm">
          <%= link_to "Dashboard", admin_root_path, class: "block px-3 py-2 rounded hover:bg-gray-100" %>
          <%= link_to "Agendamentos", admin_bookings_path, class: "block px-3 py-2 rounded hover:bg-gray-100" %>
          <%= link_to "Pagamentos", admin_payments_path, class: "block px-3 py-2 rounded hover:bg-gray-100" %>
          <%= link_to "Serviços", admin_services_path, class: "block px-3 py-2 rounded hover:bg-gray-100" %>
          <%= link_to "Horários", admin_availabilities_path, class: "block px-3 py-2 rounded hover:bg-gray-100" %>
          <% if current_user.owner? %>
            <%= link_to "Usuários", admin_users_path, class: "block px-3 py-2 rounded hover:bg-gray-100" %>
            <%= link_to "Descontos", admin_discount_rules_path, class: "block px-3 py-2 rounded hover:bg-gray-100" %>
            <%= link_to "Configurações", edit_admin_clinic_path(current_user.clinic), class: "block px-3 py-2 rounded hover:bg-gray-100" %>
          <% end %>
        </nav>
        <div class="px-4 py-4 border-t text-sm">
          <p class="text-gray-600 truncate"><%= current_user.name %></p>
          <%= button_to "Sair", destroy_user_session_path, method: :delete,
                class: "mt-2 text-xs text-red-500 hover:text-red-700" %>
        </div>
      </aside>

      <div class="flex-1 overflow-auto">
        <% if notice.present? %>
          <div class="bg-green-50 border-b border-green-200 text-green-800 px-6 py-3 text-sm"><%= notice %></div>
        <% end %>
        <% if alert.present? %>
          <div class="bg-red-50 border-b border-red-200 text-red-800 px-6 py-3 text-sm"><%= alert %></div>
        <% end %>
        <main class="p-8">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
