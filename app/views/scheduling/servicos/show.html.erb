<% content_for :title, @service.name %>

<%= render "shared/back_button", path: servicos_path %>

<div class="mb-5">
  <h1 class="text-2xl font-semibold mb-1" style="color: #5D4037"><%= @service.name %></h1>
  <p class="text-sm" style="color: #8D6E63">
    <%= @service.duration_minutes %> min · R$ <%= money(@service.price_cents) %> por sessão
  </p>
</div>

<div class="bg-white rounded-2xl shadow-sm p-4 mb-4">
  <div class="flex items-center gap-2">
    <%= link_to "‹", servico_path(@service, date: @date - 7.days),
          class: "p-2 rounded-full hover:bg-white/50 text-lg leading-none",
          style: "color: #5D4037" %>
    <%= form_with url: servico_path(@service), method: :get, data: { turbo: false }, class: "flex-1" do |f| %>
      <%= f.date_field :date, value: @date,
            class: "w-full px-4 py-3 rounded-2xl border text-sm bg-white",
            style: "border-color: #E0E0E0; color: #3E2723",
            onchange: "this.form.submit()" %>
    <% end %>
    <%= link_to "›", servico_path(@service, date: @date + 7.days),
          class: "p-2 rounded-full hover:bg-white/50 text-lg leading-none",
          style: "color: #5D4037" %>
  </div>
  <p class="text-xs text-center mt-2" style="color: #8D6E63">
    Semana de <%= l(@date.beginning_of_week, format: :default) %> a <%= l(@date.end_of_week, format: :default) %>
  </p>
</div>

<%= turbo_frame_tag "cart-summary" do %>
  <%= render "shared/cart_summary" %>
<% end %>

<% if @availabilities.empty? %>
  <div class="text-center py-12">
    <p class="text-sm" style="color: #8D6E63">Nenhum horário disponível nesta semana.</p>
    <p class="text-xs mt-1" style="color: #8D6E63">Tente navegar para outra semana.</p>
  </div>
<% else %>
  <div class="flex flex-col gap-2">
    <% @availabilities.group_by(&:date).each do |date, slots| %>
      <p class="text-xs font-semibold uppercase tracking-wide mt-3 mb-1" style="color: #8D6E63">
        <%= l(date, format: :long) %>
      </p>
      <% slots.each do |av| %>
        <%= render "shared/slot_card", availability: av %>
      <% end %>
    <% end %>
  </div>
<% end %>
