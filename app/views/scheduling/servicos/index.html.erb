<% content_for :title, "Serviços" %>

<div class="mb-6 text-center">
  <h1 class="text-2xl font-semibold mb-1" style="color: #5D4037">Nossos serviços</h1>
  <p class="text-sm" style="color: #8D6E63">Escolha uma especialidade para ver os horários disponíveis.</p>
</div>

<% if @services.empty? %>
  <div class="text-center py-12">
    <p class="text-sm" style="color: #8D6E63">Nenhum serviço disponível no momento.</p>
  </div>
<% else %>
  <div class="flex flex-col gap-3">
    <% @services.each do |service| %>
      <%= link_to servico_path(service),
            class: "bg-white rounded-2xl shadow-sm p-5 flex items-center justify-between transition-all hover:shadow-md active:scale-[0.98]" do %>
        <div>
          <p class="font-medium text-sm" style="color: #3E2723"><%= service.name %></p>
          <p class="text-xs mt-1" style="color: #8D6E63"><%= service.duration_minutes %> min por sessão</p>
        </div>
        <div class="text-right">
          <p class="text-lg font-bold" style="color: #5D4037">R$ <%= money(service.price_cents) %></p>
          <p class="text-xs" style="color: #C9B8A8">ver horários →</p>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
