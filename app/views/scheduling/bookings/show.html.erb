<% content_for :title, "Reserva ##{@booking_group.id.split('-').first}" %>

<%= render "shared/back_button", path: reservas_path %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-medium text-vdc-primary">Reserva</h1>
  <span class="<%= booking_group_status_badge(@booking_group.status) %>">
    <%= t("booking_group.status.#{@booking_group.status}") %>
  </span>
</div>

<div class="flex flex-col gap-3 mb-4">
  <% @booking_group.bookings.includes(:availability).each do |b| %>
    <div class="bg-white rounded-2xl shadow-sm p-4 flex justify-between items-start">
      <div>
        <p class="font-medium text-sm text-vdc-foreground"><%= b.availability.label %></p>
        <p class="text-xs mt-1 text-vdc-secondary">
          <%= l(b.availability.date, format: :default) %> · <%= b.availability.time_range %>
        </p>
        <% if b.confirmed? && b.availability.cancellable? %>
          <%= button_to cancelar_reserva_path(b), method: :patch,
                class: "btn-xs-danger mt-2 cursor-pointer",
                data: { turbo_confirm: "Cancelar esta reserva?" } do %>
            Cancelar este horário
          <% end %>
        <% end %>
      </div>
      <span class="text-sm font-medium text-vdc-primary">
        R$ <%= money(b.price_cents) %>
      </span>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-3xl shadow-lg p-6 mb-4">
  <% if @booking_group.discount_cents > 0 %>
    <div class="flex justify-between text-sm mb-2 text-vdc-secondary">
      <span>Subtotal</span>
      <span>R$ <%= money(@booking_group.subtotal_cents) %></span>
    </div>
    <div class="flex justify-between text-sm mb-2 text-vdc-success">
      <span>Desconto</span>
      <span>− R$ <%= money(@booking_group.discount_cents) %></span>
    </div>
  <% end %>
  <div class="flex justify-between font-medium border-vdc-default <%= 'border-t pt-3 mt-1' if @booking_group.discount_cents > 0 %>">
    <span class="text-vdc-foreground">Total</span>
    <span class="text-xl font-medium text-vdc-primary">
      R$ <%= money(@booking_group.total_cents) %>
    </span>
  </div>
</div>

<% if @booking_group.pending? && @booking_group.payment.present? %>
  <%= link_to "Ver QR Code Pix →", pagamento_path(@booking_group.payment), class: "btn-cta" %>
<% end %>

<%# Diferença pendente (alteração de turno para valor maior) %>
<% @booking_group.payments.where(gateway: "infinitepay", status: "pending")
     .where.not(id: @booking_group.payment&.id).each do |dp| %>
  <div class="mt-3">
    <p class="text-xs mb-2 text-center" style="color:#8D6E63">
      Diferença pendente da alteração de turno
    </p>
    <%= link_to "Pagar diferença · R$ #{money(dp.amount_cents)} →", pagamento_path(dp), class: "btn-cta" %>
  </div>
<% end %>
