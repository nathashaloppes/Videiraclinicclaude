<% content_for :title, "Confirmar reserva" %>

<%= render "shared/back_button", path: carrinho_path %>

<h1 class="text-2xl font-medium mb-6" style="color: #5D4037">Confirmar reserva</h1>

<div class="flex flex-col gap-3 mb-4">
  <% @pricing[:availabilities].each do |av| %>
    <div class="bg-white rounded-2xl shadow-sm p-4 flex justify-between items-center">
      <div>
        <p class="font-medium text-sm" style="color: #3E2723"><%= av.label %></p>
        <p class="text-xs mt-1" style="color: #8D6E63">
          <%= l(av.date, format: :default) %> · <%= av.starts_at.strftime("%H:%M") %>–<%= av.ends_at.strftime("%H:%M") %>
        </p>
      </div>
      <span class="text-sm font-semibold" style="color: #5D4037">
        R$ <%= money(av.price_cents) %>
      </span>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-3xl shadow-lg p-6 mb-6">
  <div class="flex justify-between text-sm mb-3" style="color: #8D6E63">
    <span>Subtotal (<%= pluralize(@pricing[:availabilities].size, "horário", "horários") %>)</span>
    <span>R$ <%= number_with_precision(@pricing[:subtotal_cents] / 100.0, precision: 2, delimiter: ".", separator: ",") %></span>
  </div>

  <% if @pricing[:discount_cents] > 0 %>
    <div class="flex justify-between text-sm mb-3 px-3 py-2 rounded-xl"
         style="background-color: #E8F5E9; color: #388E3C">
      <span>Desconto (<%= @pricing[:discount_percent] %>%)</span>
      <span>− R$ <%= money(@pricing[:discount_cents]) %></span>
    </div>
  <% end %>

  <% credit_balance = Credit.balance_for(user: current_user, clinic: current_user.clinic) %>
  <% credit_applied = [credit_balance, @pricing[:total_cents]].min %>
  <% if credit_applied > 0 %>
    <div class="flex justify-between text-sm mb-3 px-3 py-2 rounded-xl"
         style="background-color: #E8F5E9; color: #388E3C">
      <span>Crédito aplicado</span>
      <span>− R$ <%= money(credit_applied) %></span>
    </div>
  <% end %>

  <% amount_due = @pricing[:total_cents] - credit_applied %>
  <div class="flex justify-between font-semibold border-t pt-4" style="border-color: #E0E0E0">
    <span style="color: #3E2723"><%= amount_due.zero? ? "Total" : "Total a pagar via Pix" %></span>
    <span class="text-xl font-bold" style="color: #5D4037">
      R$ <%= money(amount_due) %>
    </span>
  </div>
</div>

<%= button_to confirmar_reservas_path, method: :post,
      class: "w-full py-3 rounded-full text-white text-sm font-medium",
      style: "background-color: #5D4037" do %>
  <%= amount_due.zero? ? "Confirmar reserva →" : "Confirmar e gerar Pix →" %>
<% end %>

<p class="mt-4 text-xs text-center" style="color: #8D6E63">
  Após confirmar, você terá <%= ENV.fetch("PAYMENT_EXPIRY_MINUTES", 30) %> minutos para concluir o pagamento via Pix.
</p>
