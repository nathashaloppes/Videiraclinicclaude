<% content_for :title, "Confirmar reserva" %>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Confirmar reserva</h1>

  <%# Resumo dos slots %>
  <div class="bg-white rounded-xl border border-gray-200 divide-y divide-gray-100 mb-4">
    <% @pricing[:availabilities].each do |av| %>
      <div class="px-5 py-4 flex justify-between items-center">
        <div>
          <p class="font-medium text-gray-900"><%= av.service.name %></p>
          <p class="text-sm text-gray-500">
            <%= l(av.date, format: :default) %> · <%= av.starts_at.strftime("%H:%M") %>–<%= av.ends_at.strftime("%H:%M") %>
          </p>
        </div>
        <span class="text-sm font-semibold text-gray-700">
          R$ <%= number_with_precision(av.service.price, precision: 2, delimiter: ".", separator: ",") %>
        </span>
      </div>
    <% end %>
  </div>

  <%# Totais %>
  <div class="bg-gray-50 rounded-xl border border-gray-200 p-5 space-y-2 text-sm mb-6">
    <div class="flex justify-between text-gray-600">
      <span>Subtotal (<%= pluralize(@pricing[:availabilities].size, "horário", "horários") %>)</span>
      <span>R$ <%= number_with_precision(@pricing[:subtotal_cents] / 100.0, precision: 2, delimiter: ".", separator: ",") %></span>
    </div>

    <% if @pricing[:discount_cents] > 0 %>
      <div class="flex justify-between text-green-700">
        <span>Desconto (<%= @pricing[:discount_percent] %>%)</span>
        <span>− R$ <%= number_with_precision(@pricing[:discount_cents] / 100.0, precision: 2, delimiter: ".", separator: ",") %></span>
      </div>
    <% end %>

    <div class="flex justify-between font-bold text-lg text-gray-900 pt-2 border-t border-gray-200">
      <span>Total</span>
      <span class="text-blue-700">R$ <%= number_with_precision(@pricing[:total_cents] / 100.0, precision: 2, delimiter: ".", separator: ",") %></span>
    </div>
  </div>

  <%# Botão de confirmação %>
  <%= button_to confirmar_reservas_path, method: :post,
        class: "w-full py-3 bg-blue-600 text-white rounded-xl font-bold text-base hover:bg-blue-700 transition" do %>
    Pagar com Pix →
  <% end %>

  <div class="mt-3 text-center">
    <%= link_to "← Voltar ao carrinho", carrinho_path, class: "text-sm text-gray-500 hover:underline" %>
  </div>

  <p class="mt-4 text-xs text-center text-gray-400">
    Após confirmar, você terá <%= ENV.fetch("PAYMENT_EXPIRY_MINUTES", 30) %> minutos para concluir o pagamento via Pix.
  </p>
</div>
