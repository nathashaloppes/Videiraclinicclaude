<% content_for :title, "Confirmar reserva" %>

<%= render "shared/back_button", path: carrinho_path %>

<h1 class="text-2xl font-medium mb-6 text-vdc-primary">Confirmar reserva</h1>

<div class="flex flex-col gap-3 mb-4">
  <% @pricing[:availabilities].each do |av| %>
    <div class="bg-white rounded-2xl shadow-sm p-4 flex justify-between items-center">
      <div>
        <p class="font-medium text-sm text-vdc-foreground"><%= av.label %></p>
        <p class="text-xs mt-1 text-vdc-secondary">
          <%= l(av.date, format: :default) %> · <%= av.time_range %>
        </p>
      </div>
      <span class="text-sm font-medium text-vdc-primary">
        R$ <%= money(av.price_cents) %>
      </span>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-3xl shadow-lg p-6 mb-6">
  <div class="flex justify-between text-sm mb-3 text-vdc-secondary">
    <span>Subtotal (<%= pluralize(@pricing[:availabilities].size, "horário", "horários") %>)</span>
    <span>R$ <%= money(@pricing[:subtotal_cents]) %></span>
  </div>

  <% if @pricing[:discount_cents] > 0 %>
    <div class="flex justify-between text-sm mb-3 px-3 py-2 rounded-2xl bg-vdc-success-light text-vdc-success">
      <span>Desconto (<%= @pricing[:discount_percent] %>%)</span>
      <span>− R$ <%= money(@pricing[:discount_cents]) %></span>
    </div>
  <% end %>

  <% unless current_user.owner? %>
    <% credit_balance = Credit.balance_for(user: current_user, clinic: current_user.clinic) %>
    <% credit_applied = [credit_balance, @pricing[:total_cents]].min %>
    <% if credit_applied > 0 %>
      <div class="flex justify-between text-sm mb-3 px-3 py-2 rounded-2xl bg-vdc-success-light text-vdc-success">
        <span>Crédito aplicado</span>
        <span>− R$ <%= money(credit_applied) %></span>
      </div>
    <% end %>
  <% end %>

  <% amount_due = current_user.owner? ? @pricing[:total_cents] : (@pricing[:total_cents] - (defined?(credit_applied) ? credit_applied : 0)) %>
  <div class="flex justify-between font-medium border-t pt-4 border-vdc-default">
    <span class="text-vdc-foreground"><%= (current_user.owner? || amount_due.zero?) ? "Total" : "Total a pagar via Pix" %></span>
    <span class="text-xl font-medium text-vdc-primary">
      R$ <%= money(amount_due) %>
    </span>
  </div>
</div>

<%= form_with url: confirmar_reservas_path, method: :post,
      data: { turbo: false, controller: current_user.owner? ? "book-slot" : nil } do |f| %>

  <% if current_user.owner? %>
    <div class="bg-white rounded-2xl shadow-sm p-4 mb-4 flex flex-col gap-3">
      <p class="text-sm font-medium" style="color: #5D4037">Para qual dentista?</p>

      <div>
        <label class="label">Buscar dentista</label>
        <input type="text" placeholder="Digite o nome..."
               class="input-field"
               data-book-slot-target="search"
               data-action="input->book-slot#filter"
               autocomplete="off">
      </div>

      <div>
        <label class="label">Dentista</label>
        <%= f.select :dentist_id,
              @dentists.map { |d| [d.name, d.id] },
              { prompt: "Selecione um dentista" },
              class: "input-field",
              data: { "book-slot-target": "select" },
              required: true %>
      </div>

      <button type="button"
              data-action="click->book-slot#openQuickCreate"
              class="text-xs text-left cursor-pointer"
              style="color: #8D6E63">
        + Cadastrar novo dentista
      </button>
    </div>
  <% end %>

  <% confirm_label = current_user.owner? ? "Confirmar reserva →" : (amount_due.zero? ? "Confirmar reserva →" : "Confirmar e gerar Pix →") %>
  <%= f.submit confirm_label, class: "btn-cta" %>

<% end %>

<% unless current_user.owner? %>
  <p class="mt-4 text-xs text-center text-vdc-secondary">
    Após confirmar, você terá <%= ENV.fetch("PAYMENT_EXPIRY_MINUTES", 30) %> minutos para concluir o pagamento via Pix.
  </p>
<% end %>

<% if current_user.owner? %>
  <dialog id="quick-create-dentist-modal" onclick="if(event.target===this)this.close()">
    <div class="p-6">
      <div class="flex items-center justify-between mb-5">
        <h2 class="font-medium text-sm" style="color: #5D4037">Cadastrar dentista</h2>
        <button type="button" onclick="this.closest('dialog').close()"
                class="p-1 rounded-full hover:bg-[#fef8e1] cursor-pointer shrink-0" aria-label="Fechar">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="color:#8D6E63">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <p class="text-xs mb-4" style="color: #8D6E63">
        O e-mail pode ser editado depois no cadastro do usuário.
      </p>
      <%= form_with url: quick_create_admin_users_path, method: :post, data: { turbo: false }, class: "flex flex-col gap-4" do %>
        <%= hidden_field_tag :return_date, @pricing[:availabilities].first&.date %>
        <div>
          <label class="label">Nome</label>
          <input type="text" name="name" class="input-field" placeholder="Nome completo" required>
        </div>
        <div>
          <label class="label">E-mail</label>
          <input type="email" name="email" class="input-field" placeholder="email@exemplo.com" required>
        </div>
        <%= render "shared/modal_actions", label: "Cadastrar" %>
      <% end %>
    </div>
  </dialog>
<% end %>
