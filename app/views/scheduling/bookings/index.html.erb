<% content_for :title, "Minhas Reservas" %>

<%= render "shared/back_button", path: root_path %>

<h1 class="text-2xl font-medium mb-6" style="color: #5D4037">Minhas reservas</h1>

<% if @booking_groups.empty? %>
  <div class="text-center py-12">
    <p class="text-sm mb-6" style="color: #8D6E63">Você ainda não tem reservas.</p>
    <%= link_to "Reservar agora →", root_path, class: "btn-cta" %>
  </div>
<% else %>
  <div class="flex flex-col gap-3 mb-4">
    <% @booking_groups.each do |group| %>
      <%= link_to reserva_path(group), class: "card-link" do %>

        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-mono" style="color: #8D6E63">#<%= group.id.split("-").first %></span>
          <span class="<%= booking_group_status_badge(group.status) %>">
            <%= t("booking_group.status.#{group.status}") %>
          </span>
        </div>

        <div class="flex flex-col gap-1 mb-3">
          <% group.bookings.each do |b| %>
            <p class="font-medium text-sm" style="color: #3E2723">
              <%= b.availability.label %>
            </p>
            <p class="text-xs" style="color: #8D6E63">
              <%= l(b.availability.date, format: :default) %> ·
              <%= b.availability.starts_at.strftime("%H:%M") %>–<%= b.availability.ends_at.strftime("%H:%M") %>
            </p>
          <% end %>
        </div>

        <div class="flex justify-between items-center border-t pt-3" style="border-color: #E0E0E0">
          <span class="text-xs" style="color: #8D6E63">
            <%= pluralize(group.bookings.size, "horário", "horários") %>
          </span>
          <span class="text-sm font-medium" style="color: #5D4037">
            R$ <%= money(group.total_cents) %>
          </span>
        </div>

      <% end %>
    <% end %>
  </div>

  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
<% end %>
