<% if cart_availabilities.empty? %>
  <div class="empty-state">
    <p class="mb-4">Seu carrinho está vazio.</p>
    <%= link_to "Ver horários disponíveis", root_path, class: "btn-cta" %>
  </div>
<% else %>
  <div class="flex flex-col gap-3 mb-4">
    <% cart_availabilities.each do |av| %>
      <div id="cart-item-<%= av.id %>" class="bg-white rounded-2xl shadow-sm p-4 flex items-center justify-between">
        <div class="flex-1 min-w-0">
          <p class="font-medium text-sm" style="color: #3E2723">
            <%= l(av.date, format: "%d/%m") %> · <%= av.label.downcase %>
          </p>
          <p class="text-xs mt-0.5" style="color: #8D6E63">
            <%= av.starts_at.strftime("%H:%M") %> - <%= av.ends_at.strftime("%H:%M") %>
          </p>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <span class="text-sm font-medium" style="color: #5D4037">
            R$ <%= money(av.price_cents) %>
          </span>
          <%= button_to remove_from_carrinho_path(availability_id: av.id),
                method: :delete, data: { turbo_stream: true },
                class: "p-1.5 rounded-full cursor-pointer",
                style: "background: transparent; color: #8D6E63" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2" style="color: #8D6E63">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <% subtotal_cents = cart_availabilities.sum(&:price_cents) %>
  <div class="rounded-2xl p-4 mb-6" style="background-color: #fef8e1">
    <div class="flex justify-between text-sm mb-2" style="color: #8D6E63">
      <span>Subtotal</span>
      <span>R$ <%= money(subtotal_cents) %></span>
    </div>
    <div class="flex justify-between font-medium border-t pt-3" style="border-color: #E0D5C0">
      <span style="color: #3E2723">TOTAL</span>
      <span class="text-lg font-medium" style="color: #5D4037">
        R$ <%= money(subtotal_cents) %>
      </span>
    </div>
  </div>

  <%= link_to "FINALIZAR PEDIDO", confirmar_reservas_path,
        class: "btn-primary w-full text-center block py-4 text-sm uppercase tracking-wide" %>
<% end %>
