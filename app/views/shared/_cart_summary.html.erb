<% cart_ids = Array(session[:cart_ids]) %>
<% count = cart_ids.size %>

<% if count > 0 %>
  <div class="fixed bottom-0 left-0 right-0 z-50 pointer-events-none">
    <div class="max-w-md mx-auto px-4 pb-6 pt-2 pointer-events-auto">
      <div class="rounded-2xl shadow-xl px-4 py-3 flex items-center justify-between gap-3"
           style="background-color: #ffffff">
        <span class="text-sm font-medium whitespace-nowrap" style="color: #3E2723">
          <%= count %> <%= count == 1 ? "turno selecionado" : "turnos selecionados" %>
        </span>
        <%= button_to carrinho_path, method: :delete,
              class: "btn-sm-outline shrink-0",
              data: { turbo: false } do %>
          Limpar seleção
        <% end %>
        <%= link_to confirmar_reservas_path,
              class: "btn-sm-primary shrink-0" do %>
          Confirmar →
        <% end %>
      </div>
    </div>
  </div>
<% end %>
