<% cart_ids = Array(session[:cart_ids]) %>
<% count = cart_ids.size %>

<% if count > 0 %>
  <div class="fixed bottom-0 left-0 right-0 z-50 pointer-events-none">
    <div class="max-w-md mx-auto px-4 pb-6 pt-2 pointer-events-auto">
      <div class="rounded-2xl shadow-xl px-4 py-3 flex flex-col gap-2"
           style="background-color: #ffffff">
        <span class="text-xs text-center font-medium" style="color: #8D6E63">
          <%= count %> <%= count == 1 ? "turno selecionado" : "turnos selecionados" %>
        </span>
        <div class="flex items-center gap-2">
          <%= link_to carrinho_path,
                class: "btn-sm-outline flex-1 text-center",
                data: { turbo_frame: "_top" } do %>
            Ver seleção
          <% end %>
          <%= link_to confirmar_reservas_path,
                class: "btn-sm-primary flex-1 text-center",
                data: { turbo_frame: "_top" } do %>
            Confirmar →
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
