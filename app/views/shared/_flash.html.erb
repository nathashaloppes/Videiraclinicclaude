<% flash.each do |type, message| %>
  <% alert  = type.to_s == "alert" %>
  <% border = alert ? "#C62828" : "#5D4037" %>
  <% bg     = alert ? "#FDE8EC" : "#F5F0ED" %>
  <% color  = alert ? "#7B0E22" : "#3E2723" %>

  <div class="fixed top-4 inset-x-4 z-50 max-w-md mx-auto"
       data-controller="flash"
       data-flash-timeout-value="4000"
       data-action="click->flash#dismiss">
    <div class="flex items-start gap-3 px-4 py-3 rounded-2xl shadow-lg"
         style="background-color: <%= bg %>; border-left: 4px solid <%= border %>">

      <%# Icon %>
      <% if alert %>
        <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" style="color: <%= border %>">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
      <% else %>
        <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" style="color: <%= border %>">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      <% end %>

      <%# Message %>
      <p class="flex-1 text-sm font-medium leading-snug" style="color: <%= color %>">
        <%= message %>
      </p>

      <%# Dismiss button %>
      <button type="button" class="shrink-0 mt-0.5 opacity-50 hover:opacity-100 transition-opacity"
              style="color: <%= color %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
<% end %>
