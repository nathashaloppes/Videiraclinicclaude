<%# Layout partial — use with: render layout: "shared/modal", locals: { id:, title: } do ... end %>
<%# Locals: id (String), title (String) %>
<dialog id="<%= id %>" onclick="if(event.target===this)this.close()">
  <div class="p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-semibold text-sm" style="color: #5D4037"><%= title %></h2>
      <button type="button" onclick="this.closest('dialog').close()"
              class="p-1 rounded-full hover:bg-gray-100 cursor-pointer shrink-0"
              aria-label="Fechar">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="color:#8D6E63">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <%= yield %>
  </div>
</dialog>
