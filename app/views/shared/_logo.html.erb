<%# Uso: <%= render 'shared/logo', size: 'sm' | 'md' | 'lg' | 'full' %>
<% size = local_assigns[:size] || 'md' %>
<% sizes = {
     'sm'   => 'h-8 w-auto',
     'md'   => 'h-10 w-auto',
     'lg'   => 'h-14 w-auto',
     'full' => 'w-72 h-auto'
   } %>

<%= image_tag "logo.jpeg",
      alt: "Videira Clinic",
      class: "#{sizes[size]} object-contain" %>
