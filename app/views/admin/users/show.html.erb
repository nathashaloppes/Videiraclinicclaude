<% content_for :title, @user.name %>
<% content_for :hide_admin_chrome, true %>

<%# Header: back + nome + editar %>
<div class="flex items-center justify-between mb-4">
  <%= render "shared/back_button", path: admin_users_path %>
  <h1 class="text-base font-medium" style="color: #3E2723"><%= @user.name %></h1>
  <button type="button" onclick="<%= open_modal('edit-user-modal') %>"
          class="p-1.5 cursor-pointer">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="1.5" style="color: #8D6E63">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
    </svg>
  </button>
</div>

<%# Avatar %>
<div class="flex justify-center mb-4">
  <%= render "shared/avatar", user: @user, size: "lg" %>
</div>

<%# Informações com ícones %>
<div class="bg-white rounded-2xl shadow-sm p-4 mb-4 flex flex-col gap-3">
  <% if @user.cro.present? %>
    <div class="flex items-center gap-3 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
           stroke="currentColor" stroke-width="1.5" style="color: #8D6E63">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
      </svg>
      <span style="color: #3E2723"><%= format_cro(@user.cro) %></span>
    </div>
  <% end %>
  <% if @user.specialty.present? %>
    <div class="flex items-center gap-3 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
           stroke="currentColor" stroke-width="1.5" style="color: #8D6E63">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      <span style="color: #3E2723"><%= @user.specialty %></span>
    </div>
  <% end %>
  <% if @user.birth_date.present? %>
    <div class="flex items-center gap-3 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
           stroke="currentColor" stroke-width="1.5" style="color: #8D6E63">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <span style="color: #3E2723">Nascida em <%= l(@user.birth_date, format: "%d/%m/%Y") %></span>
    </div>
  <% end %>
  <% if @user.phone.present? %>
    <div class="flex items-center gap-3 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
           stroke="currentColor" stroke-width="1.5" style="color: #8D6E63">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
      </svg>
      <span style="color: #3E2723"><%= format_phone(@user.phone) %></span>
    </div>
  <% end %>
  <div class="flex items-center gap-3 text-sm">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="1.5" style="color: #8D6E63">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>
    <span style="color: #3E2723"><%= @user.email %></span>
  </div>
  <% if @user.cpf.present? %>
    <div class="flex items-center gap-3 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
           stroke="currentColor" stroke-width="1.5" style="color: #8D6E63">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0M9 14h6"/>
      </svg>
      <span style="color: #3E2723">CPF <%= format_cpf(@user.cpf) %></span>
    </div>
  <% end %>
</div>

<%# Carteira do cliente %>
<% credit_cents = Credit.balance_for(user: @user, clinic: current_user.clinic) %>
<div class="bg-white rounded-2xl shadow-sm p-4 mb-4">
  <h2 class="font-medium mb-3 text-sm" style="color: #5D4037">Carteira do cliente</h2>
  <div class="flex items-center gap-3 mb-3">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="1.5" style="color: #8D6E63">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M21 12V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h14a2 2 0 002-2v-5z"/>
      <path stroke-linecap="round" stroke-linejoin="round" d="M16 12a1 1 0 100 2 1 1 0 000-2z"/>
    </svg>
    <div>
      <p class="text-xs" style="color: #8D6E63">Saldo disponível</p>
      <p class="text-lg font-medium" style="color: #5D4037">R$ <%= money(credit_cents) %></p>
    </div>
  </div>
  <div class="flex gap-2">
    <button type="button" onclick="<%= open_modal("add-credit-#{@user.id}") %>"
            class="flex-1 py-2 rounded-full text-xs font-medium cursor-pointer"
            style="background-color: #C9B8A8; color: #3E2723">
      Adicionar crédito
    </button>
    <% if credit_cents > 0 %>
      <button type="button" onclick="<%= open_modal("remove-credit-#{@user.id}") %>"
              class="flex-1 py-2 rounded-full text-xs font-medium cursor-pointer border"
              style="border-color: #d4183d; color: #d4183d; background: transparent">
        Excluir crédito
      </button>
    <% end %>
  </div>
</div>

<%# Histórico de transações %>
<div class="bg-white rounded-2xl shadow-sm p-4 mb-4">
  <div class="mb-3">
    <h2 class="font-medium text-sm" style="color: #5D4037">Histórico de transações</h2>
  </div>
  <% if @booking_groups.empty? %>
    <p class="text-sm" style="color: #8D6E63">Sem transações.</p>
  <% else %>
    <div class="flex flex-col gap-0">
      <% @booking_groups.each_with_index do |group, i| %>
        <div class="flex items-center justify-between py-3 <%= i > 0 ? 'border-t' : '' %>"
             style="border-color: #F5F5F5">
          <div>
            <p class="text-sm" style="color: #3E2723">
              <%= l(group.created_at.to_date, format: "%A, %-d de %B") %>
            </p>
            <% group.bookings.each do |b| %>
              <p class="text-xs" style="color: #8D6E63">
                , <%= b.availability.starts_at.strftime("%H:%M") %> às <%= b.availability.ends_at.strftime("%H:%M") %>
              </p>
            <% end %>
          </div>
          <span class="text-sm font-medium" style="color: #5D4037">
            R$ <%= money(group.total_cents) %>
          </span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%# Apagar cliente %>
<div class="mb-6">
  <button type="button" onclick="<%= open_modal("delete-user-#{@user.id}") %>"
          class="w-full py-3 rounded-full text-sm font-medium cursor-pointer"
          style="border: 1px solid #d4183d; color: #d4183d; background: transparent">
    Apagar cliente
  </button>
</div>

<%# Modal: Editar informações %>
<%= render layout: "shared/modal", locals: { id: "edit-user-modal", title: "Alterar informações" } do %>
  <div class="flex justify-center mb-4">
    <%= render "shared/avatar", user: @user, size: "md" %>
  </div>
  <%= render "admin/users/edit_form", user: @user %>
<% end %>

<%# Modal: Adicionar crédito %>
<%= render layout: "shared/modal", locals: { id: "add-credit-#{@user.id}", title: "Adicionar Crédito" } do %>
  <%= form_with url: add_credit_admin_user_path(@user), method: :post, data: { turbo: false }, class: "flex flex-col gap-4" do %>
    <div>
      <label class="label">Valor</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <input type="text" inputmode="numeric" name="amount" placeholder="R$ 0,00"
               data-controller="input-mask" data-input-mask-pattern-value="money"
               class="w-full bg-transparent border-none outline-none py-3 text-sm"
               style="color: #3E2723">
      </div>
    </div>
    <div class="flex gap-3">
      <button type="button" onclick="this.closest('dialog').close()"
              class="btn-outline flex-1 cursor-pointer">Cancelar</button>
      <button type="submit" class="btn-primary flex-1 cursor-pointer">Adicionar</button>
    </div>
  <% end %>
<% end %>

<%# Modal: Excluir crédito %>
<% if credit_cents > 0 %>
  <%= render layout: "shared/modal", locals: { id: "remove-credit-#{@user.id}", title: "Excluir Crédito" } do %>
    <p class="text-sm mb-3" style="color: #8D6E63">
      Crédito disponível: R$ <%= money(credit_cents) %>
    </p>
    <%= form_with url: remove_credit_admin_user_path(@user), method: :delete, data: { turbo: false }, class: "flex flex-col gap-4" do %>
      <div>
        <label class="label">Valor a excluir</label>
        <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
          <input type="text" inputmode="numeric" name="amount" placeholder="R$ 0,00"
                 data-controller="input-mask" data-input-mask-pattern-value="money"
                 class="w-full bg-transparent border-none outline-none py-3 text-sm"
                 style="color: #3E2723">
        </div>
      </div>
      <div class="flex gap-3">
        <button type="button" onclick="this.closest('dialog').close()"
                class="btn-outline flex-1 cursor-pointer">Cancelar</button>
        <button type="submit"
                class="flex-1 py-3 rounded-full text-sm font-medium cursor-pointer text-white"
                style="background-color: #d4183d">
          Excluir
        </button>
      </div>
    <% end %>
  <% end %>
<% end %>

<%# Modal: Confirmar apagar cliente %>
<%= render "shared/confirm_modal", id: "delete-user-#{@user.id}",
      message: "Tem certeza que deseja apagar cliente?",
      confirm_path: admin_user_path(@user), confirm_method: :delete,
      confirm_label: "Excluir", danger: true %>
