<% content_for :title, "Editar #{@user.name}" %>

<div class="max-w-lg">
  <div class="mb-4">
    <%= link_to "← #{@user.name}", admin_user_path(@user), class: "text-sm text-gray-500 hover:underline" %>
  </div>
  <h1 class="text-xl font-bold text-gray-900 mb-6">Editar dentista</h1>

  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <p class="text-xs text-gray-400 mb-5 bg-yellow-50 border border-yellow-200 rounded-lg px-3 py-2">
      O e-mail não pode ser alterado por este painel.
    </p>

    <%= form_with model: [:admin, @user], class: "space-y-4" do |f| %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
          <ul class="list-disc list-inside">
            <% @user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Nome", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500" %>
      </div>
      <div>
        <%= f.label :phone, "Telefone", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.telephone_field :phone, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :cpf, "CPF (11 dígitos)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :cpf, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :birth_date, "Data de nascimento", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :birth_date, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      </div>

      <div class="flex gap-3 pt-2">
        <%= f.submit "Salvar", class: "px-5 py-2 bg-blue-600 text-white rounded-lg font-semibold text-sm hover:bg-blue-700 cursor-pointer" %>
        <%= link_to "Cancelar", admin_user_path(@user), class: "px-5 py-2 border border-gray-300 text-gray-600 rounded-lg text-sm hover:bg-gray-50" %>
      </div>
    <% end %>
  </div>
</div>
