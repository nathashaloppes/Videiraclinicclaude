<% content_for :title, "Clientes" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-xl font-medium" style="color: #5D4037">Clientes</h1>
  <button type="button" onclick="<%= open_modal('add-client-modal') %>"
          class="flex items-center gap-1 text-xs font-medium px-4 py-2 rounded-full cursor-pointer"
          style="background-color: #E0E0E0; color: #5D4037">
    Adicionar +
  </button>
</div>

<%# Barra de pesquisa por nome ou email %>
<%= form_with url: admin_users_path, method: :get, data: { turbo: false }, class: "mb-4" do %>
  <div class="bg-white rounded-full shadow-sm px-4 flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="2" style="color:#8D6E63">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14z"/>
    </svg>
    <input type="text" name="q" value="<%= params[:q] %>" placeholder="Buscar por nome ou email"
           autocomplete="off"
           class="w-full bg-transparent border-none outline-none py-3 text-sm" style="color: #3E2723">
    <% if params[:q].present? %>
      <%= link_to admin_users_path, class: "shrink-0 p-1 rounded-full hover:bg-[#fef8e1]", "aria-label": "Limpar busca" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" style="color:#8D6E63">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      <% end %>
    <% end %>
  </div>
<% end %>

<% if @users.empty? %>
  <div class="empty-state"><p>Nenhum cliente encontrado.</p></div>
<% else %>
  <div class="bg-white rounded-2xl shadow-sm overflow-hidden mb-4">
    <% @users.each_with_index do |u, i| %>
      <%= link_to admin_user_path(u),
            class: "flex items-center gap-3 px-4 py-4 #{i > 0 ? 'border-t' : ''}",
            style: "border-color: #F5F5F5" do %>
        <%= render "shared/avatar", user: u, size: "md" %>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-sm" style="color: #3E2723"><%= u.name %></p>
          <p class="text-xs truncate" style="color: #8D6E63"><%= u.email %></p>
          <p class="text-xs mt-0.5" style="color: #8D6E63">
            <%= pluralize(u.booking_groups.where(status: ["confirmed", "cancelled"]).count, "reserva", "reservas") %>
          </p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" style="color: #C9B8A8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    <% end %>
  </div>
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
<% end %>

<%# Modal: Adicionar cliente %>
<%= render layout: "shared/modal", locals: { id: "add-client-modal", title: "Adicionar cliente" } do %>
  <%= form_with url: admin_users_path, method: :post, data: { turbo: false }, class: "flex flex-col gap-4" do |f| %>

    <div>
      <label class="label">Nome completo</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <%= f.text_field "user[name]", placeholder: "Digite o nome completo",
              class: "w-full bg-transparent border-none outline-none py-3 text-sm",
              style: "color: #3E2723" %>
      </div>
    </div>

    <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
      <%= f.text_field "user[cro]", placeholder: "CRO-XX 00000",
            class: "w-full bg-transparent border-none outline-none py-3 text-sm",
            style: "color: #3E2723",
            data: { controller: "input-mask", "input-mask-pattern-value": "cro" } %>
    </div>

    <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
      <%= f.text_field "user[specialty]", placeholder: "Área de atuação*",
            class: "w-full bg-transparent border-none outline-none py-3 text-sm",
            style: "color: #3E2723" %>
    </div>

    <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
      <%= f.text_field "user[cpf]", placeholder: "CPF (000.000.000-00)",
            class: "w-full bg-transparent border-none outline-none py-3 text-sm",
            style: "color: #3E2723",
            data: { controller: "input-mask", "input-mask-pattern-value": "cpf" } %>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <%= f.date_field "user[birth_date]", placeholder: "dd/mm/aaaa",
              class: "w-full bg-transparent border-none outline-none py-3 text-sm",
              style: "color: #3E2723" %>
      </div>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <%= f.telephone_field "user[phone]", placeholder: "(00) 00000-0000",
              class: "w-full bg-transparent border-none outline-none py-3 text-sm",
              style: "color: #3E2723",
              data: { controller: "input-mask", "input-mask-pattern-value": "phone" } %>
      </div>
    </div>

    <div>
      <label class="label">E-mail</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <%= f.email_field "user[email]", placeholder: "Digite o e-mail",
              class: "w-full bg-transparent border-none outline-none py-3 text-sm",
              style: "color: #3E2723" %>
      </div>
    </div>

    <%= render "shared/modal_actions", label: "Adicionar cliente" %>
  <% end %>
<% end %>
