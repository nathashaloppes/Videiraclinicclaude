<%# Locals: user (User) — formulário de edição reutilizado no show e no index %>
<p class="text-xs mb-4 px-3 py-2 rounded-2xl bg-vdc-warning-light text-vdc-secondary">
  O e-mail não pode ser alterado por este painel.
</p>
<%= form_with model: [:admin, user], data: { turbo: false }, class: "flex flex-col gap-4", builder: VdcFormBuilder do |f| %>
  <%= f.vdc_field :name,       "Nome" %>
  <%= f.vdc_field :phone,      "Telefone",           :telephone_field %>
  <%= f.vdc_field :cpf,        "CPF (11 dígitos)" %>
  <%= f.vdc_field :birth_date, "Data de nascimento",  :date_field %>
  <%= render "shared/modal_actions", label: "Salvar" %>
<% end %>
