<% content_for :title, "Descontos" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Regras de desconto</h1>
  <%= link_to "+ Nova regra", new_admin_discount_rule_path,
        class: "px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700" %>
</div>

<p class="text-sm text-gray-500 mb-5">
  Quanto mais horários a dentista reservar de uma vez, maior o desconto aplicado automaticamente.
</p>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="px-5 py-3 text-left font-medium text-gray-600">Mín. horários</th>
        <th class="px-5 py-3 text-left font-medium text-gray-600">Desconto</th>
        <th class="px-5 py-3 text-left font-medium text-gray-600">Status</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @rules.each do |rule| %>
        <tr class="<%= rule.active? ? '' : 'opacity-50' %> hover:bg-gray-50">
          <td class="px-5 py-4 font-semibold text-gray-900">
            <%= rule.min_slots %> ou mais
          </td>
          <td class="px-5 py-4 text-green-700 font-bold"><%= rule.discount_percent %>%</td>
          <td class="px-5 py-4">
            <span class="<%= rule.active? ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %> text-xs font-semibold px-2 py-1 rounded-full">
              <%= rule.active? ? "Ativa" : "Inativa" %>
            </span>
          </td>
          <td class="px-5 py-4 text-right flex gap-3 justify-end">
            <%= link_to "Editar", edit_admin_discount_rule_path(rule), class: "text-blue-600 hover:underline text-xs" %>
            <% if rule.active? %>
              <%= button_to "Desativar", admin_discount_rule_path(rule), method: :delete,
                    class: "text-red-500 hover:text-red-700 text-xs",
                    data: { turbo_confirm: "Desativar esta regra? Reservas existentes não são afetadas." } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
