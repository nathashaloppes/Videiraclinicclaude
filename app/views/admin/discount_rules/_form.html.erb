<%= form_with model: [:admin, rule], class: "flex flex-col gap-4" do |f| %>
  <%= render "shared/form_errors", object: rule %>

  <div>
    <%= f.label :min_slots, "Mínimo de horários", class: "label" %>
    <%= f.number_field :min_slots, min: 2, class: "input-field" %>
    <p class="text-xs mt-1 text-vdc-secondary">A partir de quantos horários o desconto é aplicado.</p>
  </div>

  <div>
    <%= f.label :discount_percent, "Desconto (%)", class: "label" %>
    <%= f.number_field :discount_percent, min: 1, max: 100, class: "input-field" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit rule.persisted? ? "Salvar alterações" : "Criar regra",
          class: "btn-primary flex-1 cursor-pointer" %>
    <%= link_to "Cancelar", admin_discount_rules_path, class: "btn-outline flex-1" %>
  </div>
<% end %>
