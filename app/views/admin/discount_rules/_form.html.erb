<%= form_with model: [:admin, rule], class: "space-y-5" do |f| %>
  <% if rule.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
      <ul class="list-disc list-inside">
        <% rule.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :min_slots, "Mínimo de horários", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :min_slots, min: 2, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500" %>
    <p class="text-xs text-gray-400 mt-1">A partir de quantos horários o desconto é aplicado.</p>
  </div>

  <div>
    <%= f.label :discount_percent, "Desconto (%)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :discount_percent, min: 1, max: 100, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit rule.persisted? ? "Salvar alterações" : "Criar regra",
          class: "px-5 py-2 bg-blue-600 text-white rounded-lg font-semibold text-sm hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Cancelar", admin_discount_rules_path,
          class: "px-5 py-2 border border-gray-300 text-gray-600 rounded-lg text-sm hover:bg-gray-50" %>
  </div>
<% end %>
