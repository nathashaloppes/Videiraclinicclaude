<% content_for :title, "Clínica" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-semibold" style="color: #5D4037">Clínica</h1>
  <button type="button" onclick="<%= open_modal('edit-clinic-modal') %>"
          class="text-xs px-4 py-2 rounded-full border cursor-pointer"
          style="border-color:#5D4037;color:#5D4037">
    Editar
  </button>
</div>

<div class="bg-white rounded-3xl shadow-lg p-6 mb-4">
  <% if @clinic.logo.attached? %>
    <div class="flex justify-center mb-5">
      <img src="<%= rails_blob_path(@clinic.logo, only_path: true) %>"
           alt="<%= @clinic.name %>"
           class="h-20 w-20 rounded-2xl object-contain shadow-sm" />
    </div>
  <% end %>

  <div class="flex flex-col gap-3 text-sm" style="color: #8D6E63">
    <div class="flex justify-between border-b pb-3" style="border-color: #E0E0E0">
      <span style="color: #3E2723">Nome</span>
      <span class="font-medium"><%= @clinic.name %></span>
    </div>
    <div class="flex justify-between border-b pb-3" style="border-color: #E0E0E0">
      <span style="color: #3E2723">CNPJ</span>
      <span><%= @clinic.cnpj %></span>
    </div>
    <div class="flex justify-between border-b pb-3" style="border-color: #E0E0E0">
      <span style="color: #3E2723">Telefone</span>
      <span><%= @clinic.phone %></span>
    </div>
    <div class="flex justify-between">
      <span style="color: #3E2723">E-mail</span>
      <span><%= @clinic.email %></span>
    </div>
  </div>
</div>

<div class="bg-white rounded-2xl shadow-sm p-5">
  <h2 class="font-semibold mb-3" style="color: #5D4037">Estatísticas</h2>
  <div class="grid grid-cols-2 gap-3">
    <div class="rounded-2xl p-4 text-center" style="background-color: #fef8e1">
      <p class="text-2xl font-bold" style="color: #5D4037"><%= @clinic.users.dentists.count %></p>
      <p class="text-xs mt-1" style="color: #8D6E63">Dentistas</p>
    </div>
    <div class="rounded-2xl p-4 text-center" style="background-color: #fef8e1">
      <p class="text-2xl font-bold" style="color: #5D4037"><%= @clinic.availabilities.where(status: :available).count %></p>
      <p class="text-xs mt-1" style="color: #8D6E63">Turnos disponíveis</p>
    </div>
  </div>
</div>

<%# ── Modal: Editar clínica ───────────────────────────────────────────────── %>
<%= render layout: "shared/modal", locals: { id: "edit-clinic-modal", title: "Editar clínica" } do %>
  <%= form_with model: [:admin, @clinic], multipart: true, data: { turbo: false }, class: "flex flex-col gap-4" do |f| %>
    <div>
      <%= f.label :name, "Nome da clínica", class: "label" %>
      <%= f.text_field :name, class: "input-field" %>
    </div>
    <div>
      <%= f.label :phone, "Telefone", class: "label" %>
      <%= f.text_field :phone, inputmode: "tel", class: "input-field" %>
    </div>
    <div>
      <%= f.label :email, "E-mail", class: "label" %>
      <%= f.email_field :email, class: "input-field" %>
    </div>
    <div>
      <%= f.label :logo, "Logo da clínica", class: "label" %>
      <% if @clinic.logo.attached? %>
        <div class="mb-2">
          <img src="<%= rails_blob_path(@clinic.logo, only_path: true) %>" alt="Logo atual"
               class="h-12 w-12 rounded-xl object-contain shadow-sm" />
        </div>
      <% end %>
      <%= f.file_field :logo, accept: "image/*", class: "w-full text-sm text-vdc-foreground" %>
    </div>
    <%= render "shared/modal_actions", label: "Salvar alterações" %>
  <% end %>
<% end %>
