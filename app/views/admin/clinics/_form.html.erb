<%= form_with model: [:admin, clinic], multipart: true, class: "flex flex-col gap-4" do |f| %>
  <%= render "shared/form_errors", object: clinic %>

  <div>
    <%= f.label :name, "Nome da clínica", class: "label" %>
    <%= f.text_field :name, class: "input-field" %>
  </div>

  <div>
    <%= f.label :cnpj, "CNPJ (14 dígitos)", class: "label" %>
    <%= f.text_field :cnpj, maxlength: 14, inputmode: "numeric", class: "input-field" %>
  </div>

  <div>
    <%= f.label :phone, "Telefone", class: "label" %>
    <%= f.text_field :phone, inputmode: "tel", class: "input-field" %>
  </div>

  <div>
    <%= f.label :email, "E-mail", class: "label" %>
    <%= f.email_field :email, class: "input-field" %>
  </div>

  <div>
    <%= f.label :logo, "Logo da clínica", class: "label" %>
    <% if clinic.logo.attached? %>
      <div class="mb-2">
        <img src="<%= rails_blob_path(clinic.logo, only_path: true) %>" alt="Logo atual"
             class="h-16 w-16 rounded-xl object-contain shadow-sm border-vdc-default" />
      </div>
    <% end %>
    <%= f.file_field :logo, accept: "image/*", class: "w-full text-sm text-vdc-foreground" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit "Salvar alterações", class: "btn-primary flex-1 cursor-pointer" %>
    <%= link_to "Cancelar", admin_clinic_path(clinic), class: "btn-outline flex-1" %>
  </div>
<% end %>
