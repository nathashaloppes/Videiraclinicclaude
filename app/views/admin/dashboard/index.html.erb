<% content_for :title, "Dashboard" %>

<h1 class="text-2xl font-medium mb-6 text-vdc-primary">Dashboard</h1>

<div class="grid grid-cols-2 gap-3 mb-6">
  <div class="card-sm">
    <p class="text-xs mb-1 text-vdc-secondary">Agendamentos hoje</p>
    <p class="text-2xl font-medium text-vdc-primary"><%= @todays_bookings %></p>
  </div>
  <div class="card-sm">
    <p class="text-xs mb-1 text-vdc-secondary">Pag. pendentes</p>
    <p class="text-2xl font-medium text-vdc-warning"><%= @pending_payments %></p>
  </div>
  <div class="card-sm col-span-2">
    <p class="text-xs mb-1 text-vdc-secondary">Receita do mês</p>
    <p class="text-2xl font-medium text-vdc-success">
      R$ <%= money(@monthly_revenue) %>
    </p>
  </div>

  <%# ── Gráfico SVG: receita dos últimos 6 meses ───────────────────────────── %>
  <div class="card-sm col-span-2">
    <p class="text-xs mb-3 text-vdc-secondary">Receita — últimos 6 meses</p>
    <% max_cents = [@monthly_series.map { |m| m[:cents] }.max || 0, 1].max %>
    <% bar_w = 36; gap = 12; chart_h = 100 %>
    <% width  = (@monthly_series.size * (bar_w + gap)) - gap %>
    <svg viewBox="0 0 <%= width %> <%= chart_h + 24 %>" class="w-full h-32">
      <% @monthly_series.each_with_index do |m, i| %>
        <% h = ((m[:cents].to_f / max_cents) * chart_h).round %>
        <% x = i * (bar_w + gap) %>
        <% y = chart_h - h %>
        <rect x="<%= x %>" y="<%= y %>" width="<%= bar_w %>" height="<%= h %>" rx="4" fill="#5D4037" />
        <text x="<%= x + (bar_w / 2) %>" y="<%= chart_h + 16 %>" text-anchor="middle"
              font-size="10" fill="#8D6E63"><%= l(m[:month], format: "%b").capitalize %></text>
      <% end %>
    </svg>
  </div>
</div>

<%# ── Google Agenda ───────────────────────────────────────────────────────── %>
<div class="card-md">
  <div class="flex items-center justify-between gap-3">
    <div>
      <p class="font-medium text-sm text-vdc-primary">Google Agenda</p>
      <% if current_user.google_refresh_token.present? %>
        <p class="text-xs mt-0.5" style="color: #388E3C">
          Conectada — reservas confirmadas viram eventos automaticamente.
        </p>
      <% else %>
        <p class="text-xs mt-0.5" style="color: #8D6E63">
          Conecte para criar eventos das reservas confirmadas na sua agenda.
        </p>
      <% end %>
    </div>
    <% if current_user.google_refresh_token.present? %>
      <%= button_to "Desconectar", admin_google_calendar_path, method: :delete,
            class: "btn-sm-outline shrink-0",
            form: { data: { turbo_confirm: "Desconectar a Google Agenda?" } } %>
    <% else %>
      <%= link_to "Conectar", admin_connect_google_calendar_path, class: "btn-sm-primary shrink-0" %>
    <% end %>
  </div>
</div>