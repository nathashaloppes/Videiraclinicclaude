<% content_for :title, "Dashboard" %>

<div class="flex items-center justify-between mb-1">
  <h1 class="text-2xl font-medium text-vdc-primary">Dashboard</h1>
  <div class="relative flex items-center gap-1.5 text-xs font-medium px-3 py-2 rounded-full bg-white shadow-sm whitespace-nowrap" style="color:#5D4037">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
    <span>Por mês</span>
    <select class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
            onchange="if(this.value) window.location='<%= admin_root_path %>?month='+this.value">
      <% @available_months.each do |m| %>
        <option value="<%= m.strftime('%Y-%m') %>" <%= "selected" if m == @month %>>
          <%= l(m, format: "%B de %Y").capitalize %>
        </option>
      <% end %>
    </select>
  </div>
</div>
<p class="text-sm mb-6 text-vdc-secondary"><%= l(@month, format: "%B de %Y").capitalize %></p>

<div class="grid grid-cols-2 gap-3 mb-6">
  <div class="card-sm">
    <p class="text-xs mb-1 text-vdc-secondary">Créditos totais</p>
    <p class="text-2xl font-medium text-vdc-primary">R$ <%= money(@total_credits) %></p>
  </div>
  <div class="card-sm">
    <p class="text-xs mb-1 text-vdc-secondary">Créditos do mês</p>
    <p class="text-2xl font-medium text-vdc-success">R$ <%= money(@monthly_credits) %></p>
  </div>
  <div class="card-sm">
    <p class="text-xs mb-1 text-vdc-secondary">Receita de turnos do mês</p>
    <p class="text-2xl font-medium text-vdc-success">R$ <%= money(@monthly_turnos) %></p>
  </div>
  <div class="card-sm">
    <p class="text-xs mb-1 text-vdc-secondary">Receita de insumos do mês</p>
    <p class="text-2xl font-medium text-vdc-success">R$ <%= money(@monthly_insumos) %></p>
  </div>
  <div class="card-sm col-span-2">
    <p class="text-xs mb-1 text-vdc-secondary">Receita total do mês</p>
    <p class="text-2xl font-medium text-vdc-success">R$ <%= money(@monthly_revenue) %></p>
  </div>

  <%# ── Gráfico: barras empilhadas (turnos/insumos/crédito) ──────────────────── %>
  <div class="card-sm col-span-2">
    <p class="text-xs mb-2 text-vdc-secondary">Receita — últimos 6 meses</p>

    <%# Legenda %>
    <div class="flex items-center gap-4 mb-3 text-[11px]" style="color:#5D4037">
      <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-full inline-block" style="background:#5D4037"></span>Turnos</span>
      <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-full inline-block" style="background:#8D6E63"></span>Insumos</span>
      <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-full inline-block" style="background:#C9B8A8"></span>Crédito</span>
    </div>

    <% max_total = [@monthly_series.map { |m| m[:total] }.max || 0, 1].max %>
    <% bar_w = 30; gap = 20; chart_h = 120; top_pad = 22; bottom_pad = 20 %>
    <% n = @monthly_series.size %>
    <% width = (n * bar_w) + ((n - 1) * gap) %>
    <% svg_h = top_pad + chart_h + bottom_pad %>
    <svg viewBox="0 0 <%= width %> <%= svg_h %>" class="w-full" style="height:11rem">
      <% @monthly_series.each_with_index do |m, i| %>
        <% x = i * (bar_w + gap) %>
        <% cx = x + bar_w / 2.0 %>
        <% total = m[:total] %>
        <% if total.positive? %>
          <% total_h = [((total.to_f / max_total) * chart_h).round, 3].max %>
          <% t_h = ((m[:turnos].to_f / total) * total_h).round %>
          <% i_h = ((m[:insumos].to_f / total) * total_h).round %>
          <% c_h = total_h - t_h - i_h %>
          <% base = top_pad + chart_h %>
          <a href="<%= admin_root_path %>?month=<%= m[:month].strftime('%Y-%m') %>" style="cursor:pointer">
            <%# turnos (base) %>
            <% if t_h.positive? %><rect x="<%= x %>" y="<%= base - t_h %>" width="<%= bar_w %>" height="<%= t_h %>" fill="#5D4037"/><% end %>
            <%# insumos %>
            <% if i_h.positive? %><rect x="<%= x %>" y="<%= base - t_h - i_h %>" width="<%= bar_w %>" height="<%= i_h %>" fill="#8D6E63"/><% end %>
            <%# crédito (topo, cantos arredondados) %>
            <% if c_h.positive? %><rect x="<%= x %>" y="<%= base - total_h %>" width="<%= bar_w %>" height="<%= c_h %>" fill="#C9B8A8" rx="3"/><% end %>
            <%# etiqueta total na ponta %>
            <text x="<%= cx %>" y="<%= base - total_h - 6 %>" text-anchor="middle" font-size="9" font-weight="500" fill="#5D4037">R$ <%= number_with_delimiter((total / 100.0).round) %></text>
          </a>
        <% end %>
        <%# rótulo do mês %>
        <text x="<%= cx %>" y="<%= svg_h - 5 %>" text-anchor="middle" font-size="10" fill="#8D6E63"><%= l(m[:month], format: "%b").capitalize %></text>
      <% end %>
    </svg>
  </div>
</div>

<%# ── Google Agenda ───────────────────────────────────────────────────────── %>
<div class="card-md">
  <div class="flex items-center justify-between gap-3">
    <div>
      <p class="font-medium text-sm text-vdc-primary">Google Agenda</p>
      <% if current_user.google_refresh_token.present? %>
        <p class="text-xs mt-0.5" style="color: #388E3C">
          Conectada — reservas confirmadas viram eventos automaticamente.
        </p>
      <% else %>
        <p class="text-xs mt-0.5" style="color: #8D6E63">
          Conecte para criar eventos das reservas confirmadas na sua agenda.
        </p>
      <% end %>
    </div>
    <% if current_user.google_refresh_token.present? %>
      <%= button_to "Desconectar", admin_google_calendar_path, method: :delete,
            class: "btn-sm-outline shrink-0",
            form: { data: { turbo_confirm: "Desconectar a Google Agenda?" } } %>
    <% else %>
      <%= link_to "Conectar", admin_connect_google_calendar_path, class: "btn-sm-primary shrink-0" %>
    <% end %>
  </div>
</div>