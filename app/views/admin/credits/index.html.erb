<% content_for :title, "Créditos" %>

<h1 class="text-2xl font-medium mb-4 text-vdc-primary">Créditos emitidos</h1>

<div class="card-sm mb-4 flex gap-2">
  <%= link_to "Todos",       admin_credits_path,
        class: params[:status].blank? ? "btn-sm-primary" : "btn-sm-outline" %>
  <%= link_to "Disponíveis", admin_credits_path(status: "available"),
        class: params[:status] == "available" ? "btn-sm-primary" : "btn-sm-outline" %>
  <%= link_to "Usados",      admin_credits_path(status: "used"),
        class: params[:status] == "used" ? "btn-sm-primary" : "btn-sm-outline" %>
</div>

<% if @credits.empty? %>
  <div class="empty-state"><p>Nenhum crédito.</p></div>
<% else %>
  <div class="flex flex-col gap-3">
    <% @credits.each do |c| %>
      <div class="card-sm">
        <div class="flex justify-between items-start mb-2">
          <div>
            <p class="text-sm font-medium text-vdc-foreground"><%= c.user.name %></p>
            <p class="text-xs text-vdc-secondary"><%= l(c.created_at, format: :default) %></p>
          </div>
          <span class="text-lg font-medium" style="color: #388E3C">
            R$ <%= money(c.amount_cents) %>
          </span>
        </div>

        <% if c.reason.present? %>
          <p class="text-xs mb-2 text-vdc-secondary"><%= c.reason %></p>
        <% end %>

        <div class="flex items-center gap-2">
          <% if c.available? %>
            <span class="badge-success">Disponível</span>
          <% else %>
            <span class="badge-warning">Usado em <%= l(c.used_at.to_date, format: :short) %></span>
          <% end %>
          <% if c.source_booking_group %>
            <%= link_to "Origem: ##{c.source_booking_group.id.split('-').first}",
                  admin_booking_path(c.source_booking_group),
                  class: "text-xs text-vdc-secondary underline" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
<% end %>
