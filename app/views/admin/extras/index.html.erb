<% content_for :title, "Extras" %>

<div class="flex items-center gap-2 mb-1 h-10">
  <%= link_to admin_availabilities_path, class: "shrink-0 p-2 -ml-2 hover:bg-white/50 rounded-full inline-block" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" style="color: #5D4037"
         fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
    </svg>
  <% end %>
  <h1 class="text-xl font-medium" style="color: #5D4037">Extras</h1>
  <button type="button" onclick="<%= open_modal('add-extra-modal') %>"
          class="ml-auto btn-sm-primary cursor-pointer flex items-center gap-1">
    + Adicionar
  </button>
</div>

<p class="text-sm mb-5" style="color: #8D6E63">
  Serviços extras que o cliente pode adicionar ao carrinho além do turno.
</p>

<% if @extras.empty? %>
  <div class="empty-state"><p>Nenhum serviço extra cadastrado.</p></div>
<% else %>
  <div class="flex flex-col gap-3">
    <% @extras.each do |extra| %>
      <div class="bg-white rounded-2xl shadow-sm p-4 flex items-center gap-3">
        <div class="flex-1 min-w-0">
          <p class="font-medium text-sm" style="color: #3E2723"><%= extra.name %></p>
          <p class="text-sm font-medium mt-1" style="color: #5D4037">R$ <%= money(extra.price_cents) %></p>
        </div>
        <button type="button" onclick="<%= open_modal("delete-extra-#{extra.id}") %>"
                class="p-2 rounded-full hover:bg-[#FFEBEE] transition-colors cursor-pointer shrink-0"
                aria-label="Excluir serviço extra">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2" style="color:#d4183d">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        </button>
      </div>
    <% end %>
  </div>
<% end %>

<%# ── Modal: Adicionar serviço extra ──────────────────────────────────────── %>
<%= render layout: "shared/modal", locals: { id: "add-extra-modal", title: "Adicionar serviço extra" } do %>
  <%= form_with url: admin_extras_path, method: :post, data: { turbo: false }, class: "flex flex-col gap-4" do %>
    <div>
      <label class="label">Nome do serviço</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <input type="text" name="extra[name]" placeholder="Ex.: Filmaker" required
               class="w-full bg-transparent border-none outline-none py-3 text-sm" style="color: #3E2723">
      </div>
    </div>
    <div>
      <label class="label">Valor</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <input type="text" inputmode="numeric" name="extra[price]" placeholder="R$ 0,00" required
               data-controller="input-mask" data-input-mask-pattern-value="money"
               class="w-full bg-transparent border-none outline-none py-3 text-sm" style="color: #3E2723">
      </div>
    </div>
    <%= render "shared/modal_actions", label: "Criar extra" %>
  <% end %>
<% end %>

<%# ── Modais: Excluir serviço extra ───────────────────────────────────────── %>
<% @extras.each do |extra| %>
  <%= render "shared/confirm_modal", id: "delete-extra-#{extra.id}",
        message: "Excluir serviço extra?",
        detail: "#{extra.name} (R$ #{money(extra.price_cents)})",
        confirm_path: admin_extra_path(extra), confirm_method: :delete,
        confirm_label: "Excluir", danger: true %>
<% end %>
