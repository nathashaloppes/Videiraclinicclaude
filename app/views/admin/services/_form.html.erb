<%= form_with model: [:admin, service], class: "flex flex-col gap-4" do |f| %>
  <%= render "shared/form_errors", object: service %>

  <div>
    <%= f.label :name, "Nome do serviço", class: "label" %>
    <%= f.text_field :name, class: "input-field", placeholder: "Ex: Consulta odontológica" %>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :duration_minutes, "Duração (min)", class: "label" %>
      <%= f.number_field :duration_minutes, min: 15, step: 15, class: "input-field" %>
    </div>
    <div>
      <%= f.label :price, "Preço (R$)", class: "label" %>
      <%= f.number_field :price, value: service.price, min: 0, step: 0.01, class: "input-field" %>
    </div>
  </div>

  <% if service.persisted? %>
    <div class="flex items-center gap-3 py-1">
      <%= f.check_box :active, style: "accent-color: #5D4037; width: 18px; height: 18px" %>
      <%= f.label :active, "Serviço ativo", class: "text-sm text-vdc-foreground" %>
    </div>
  <% end %>

  <div class="flex gap-3 pt-2">
    <%= f.submit service.persisted? ? "Salvar alterações" : "Criar serviço",
          class: "btn-primary flex-1 cursor-pointer" %>
    <%= link_to "Cancelar", admin_services_path, class: "btn-outline flex-1" %>
  </div>
<% end %>
