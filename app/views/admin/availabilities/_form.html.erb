<%= form_with model: [:admin, availability], data: { turbo: false }, class: "flex flex-col gap-4" do |f| %>
  <%= render "shared/form_errors", object: availability %>

  <div>
    <%= f.label :date, "Data", class: "label" %>
    <%= f.date_field :date, class: "input-field" %>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :starts_at, "Início", class: "label" %>
      <%= f.time_field :starts_at, class: "input-field" %>
    </div>
    <div>
      <%= f.label :ends_at, "Fim", class: "label" %>
      <%= f.time_field :ends_at, class: "input-field" %>
    </div>
  </div>

  <div>
    <%= f.label :price, "Valor (R$)", class: "label" %>
    <%= f.number_field :price,
          value: availability.persisted? ? availability.price : nil,
          step: 0.01, min: 0, placeholder: "170,00",
          class: "input-field" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit availability.persisted? ? "Salvar alterações" : "Criar turno",
          class: "btn-primary flex-1 cursor-pointer" %>
    <%= link_to "Cancelar", admin_availabilities_path(date: availability.date),
          class: "btn-outline flex-1 text-center" %>
  </div>
<% end %>
