<%= form_with model: [:admin, availability], class: "space-y-5" do |f| %>
  <% if availability.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% availability.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :service_id, "Serviço", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :service_id, @services, :id, :name,
            { prompt: "Selecione..." },
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :dentist_id, "Dentista", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :dentist_id, @dentists, :id, :name,
            { prompt: "Selecione..." },
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500" %>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div>
      <%= f.label :date, "Data", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :date, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :starts_at, "Início", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.time_field :starts_at, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :ends_at, "Fim", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.time_field :ends_at, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500" %>
    </div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit availability.persisted? ? "Salvar alterações" : "Criar horário",
          class: "px-5 py-2 bg-blue-600 text-white rounded-lg font-semibold text-sm hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Cancelar", admin_availabilities_path(date: availability.date),
          class: "px-5 py-2 border border-gray-300 text-gray-600 rounded-lg text-sm hover:bg-gray-50" %>
  </div>
<% end %>
