<% content_for :title, "Turnos" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-xl font-medium" style="color: #5D4037">Turnos</h1>
  <button type="button" onclick="<%= open_modal('add-turno-modal') %>"
          class="btn-sm-primary cursor-pointer flex items-center gap-1">
    + Adicionar
  </button>
</div>

<%# ── Date badge ─────────────────────────────────────────────────────────── %>
<div class="bg-white rounded-2xl shadow-sm px-4 py-3 mb-3 flex items-center gap-2"
     style="color: #8D6E63">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
       stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round"
          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
  </svg>
  <%= form_with url: admin_availabilities_path, method: :get, data: { turbo: false }, class: "flex-1" do |f| %>
    <%= f.date_field :date, value: @date,
          class: "w-full text-sm bg-transparent border-none outline-none cursor-pointer font-medium",
          style: "color: #5D4037",
          onchange: "this.form.submit()" %>
  <% end %>
</div>

<%# ── Week strip ─────────────────────────────────────────────────────────── %>
<% week_start = @date.beginning_of_week(:sunday) %>
<div class="bg-white rounded-2xl shadow-sm px-2 py-2 mb-5 flex items-center gap-1">
  <%= link_to admin_availabilities_path(date: (@date - 7).to_s),
        class: "shrink-0 w-7 h-7 flex items-center justify-center rounded-full text-base hover:bg-[#fef8e1]",
        style: "color: #8D6E63" do %>‹<% end %>
  <div class="flex-1 flex justify-between">
    <% 7.times do |i| %>
      <% day = week_start + i %>
      <% active = day == @date %>
      <%= link_to admin_availabilities_path(date: day.to_s),
            class: "flex flex-col items-center px-2 py-1.5 rounded-2xl transition-all",
            style: active ? "background-color: #5D4037" : "" do %>
        <span class="text-xs font-medium" style="color: <%= active ? '#ffffff' : '#8D6E63' %>">
          <%= %w[DOM SEG TER QUA QUI SEX SÁB][day.wday] %>
        </span>
        <span class="text-xs font-medium" style="color: <%= active ? '#ffffff' : '#5D4037' %>">
          <%= day.day %>
        </span>
      <% end %>
    <% end %>
  </div>
  <%= link_to admin_availabilities_path(date: (@date + 7).to_s),
        class: "shrink-0 w-7 h-7 flex items-center justify-center rounded-full text-base hover:bg-[#fef8e1]",
        style: "color: #8D6E63" do %>›<% end %>
</div>

<%# ── Lista de turnos + modais de reserva ────────────────────────────────── %>
<div data-controller="book-slot">

<% if @availabilities.empty? %>
  <div class="empty-state">
    <p>Nenhum turno cadastrado para este dia.</p>
  </div>
<% else %>
  <div class="flex flex-col gap-3">
    <% @availabilities.each do |av| %>
      <div class="bg-white rounded-2xl shadow-sm p-4 flex items-center gap-3">

        <%# Toggle switch %>
        <% if av.booked? %>
          <button type="button" onclick="<%= open_modal('turno-reservado-modal') %>"
                  class="shrink-0 inline-flex h-6 w-11 items-center rounded-full"
                  style="background-color: #E0E0E0">
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow" style="margin-left:4px"></span>
          </button>
        <% else %>
          <%= button_to toggle_admin_availability_path(av), method: :patch,
                class: "shrink-0 inline-flex h-6 w-11 items-center rounded-full transition-colors",
                style: "background-color: #{av.available? ? '#5D4037' : '#E0E0E0'}" do %>
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow transition-transform"
                  style="margin-left:<%= av.available? ? '18px' : '4px' %>"></span>
          <% end %>
        <% end %>

        <%# Info %>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-sm" style="color: #3E2723"><%= av.label %></p>
          <p class="text-xs mt-0.5" style="color: #8D6E63">
            (<%= av.starts_at.strftime("%H:%M") %> às <%= av.ends_at.strftime("%H:%M") %>)
          </p>
          <p class="text-sm font-medium mt-1" style="color: #5D4037">R$ <%= money(av.price_cents) %></p>
        </div>

        <%# Actions %>
        <div class="flex items-center gap-1 shrink-0">
          <% if av.booked? %>
            <span class="badge-warning">Reservado</span>
          <% else %>
            <% if av.available? %>
              <button type="button"
                      data-action="click->book-slot#open"
                      data-book-slot-id-param="<%= av.id %>"
                      class="btn-sm-primary cursor-pointer">
                Reservar
              </button>
            <% end %>
            <button type="button" onclick="<%= open_modal("delete-av-#{av.id}") %>"
                    class="p-2 rounded-full hover:bg-[#FFEBEE] transition-colors cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
                   stroke="currentColor" stroke-width="2" style="color:#d4183d">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
            </button>
            <button type="button" onclick="<%= open_modal("edit-av-#{av.id}") %>"
                    class="p-2 rounded-full hover:bg-[#fef8e1] transition-colors cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                   style="color:#C9B8A8">
                <circle cx="9" cy="5" r="1.5"/><circle cx="15" cy="5" r="1.5"/>
                <circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/>
                <circle cx="9" cy="19" r="1.5"/><circle cx="15" cy="19" r="1.5"/>
              </svg>
            </button>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<%# ── Modal: Reservar turno ──────────────────────────────────────────────── %>
<dialog id="book-slot-modal" onclick="if(event.target===this)this.close()">
  <div class="p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-medium text-sm" style="color: #5D4037">Reservar turno</h2>
      <button type="button" onclick="this.closest('dialog').close()"
              class="p-1 rounded-full hover:bg-[#fef8e1] cursor-pointer shrink-0" aria-label="Fechar">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="color:#8D6E63">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <%= form_with url: admin_bookings_path, method: :post, data: { turbo: false }, class: "flex flex-col gap-4" do |f| %>
      <%= hidden_field_tag :availability_id, nil, data: { "book-slot-target": "availabilityId" } %>

      <div>
        <label class="label">Buscar dentista</label>
        <input type="text" placeholder="Digite o nome..."
               class="input-field"
               data-book-slot-target="search"
               data-action="input->book-slot#filter"
               autocomplete="off">
      </div>

      <div>
        <label class="label">Dentista</label>
        <%= f.select :dentist_id,
              @dentists.map { |d| [d.name, d.id] },
              { prompt: "Selecione um dentista" },
              class: "input-field",
              data: { "book-slot-target": "select" },
              required: true %>
      </div>

      <button type="button"
              data-action="click->book-slot#openQuickCreate"
              class="text-xs text-left cursor-pointer"
              style="color: #8D6E63">
        + Cadastrar novo dentista
      </button>

      <%= render "shared/modal_actions", label: "Confirmar reserva" %>
    <% end %>
  </div>
</dialog>

<%# ── Modal: Cadastrar dentista rápido ──────────────────────────────────── %>
<dialog id="quick-create-dentist-modal" onclick="if(event.target===this)this.close()">
  <div class="p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-medium text-sm" style="color: #5D4037">Cadastrar dentista</h2>
      <button type="button" onclick="this.closest('dialog').close()"
              class="p-1 rounded-full hover:bg-[#fef8e1] cursor-pointer shrink-0" aria-label="Fechar">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="color:#8D6E63">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <p class="text-xs mb-4" style="color: #8D6E63">
      O e-mail pode ser editado depois no cadastro do usuário.
    </p>
    <%= form_with url: admin_users_path, method: :post, data: { turbo: false }, class: "flex flex-col gap-4" do %>
      <div>
        <label class="label">Nome</label>
        <input type="text" name="user[name]" class="input-field" placeholder="Nome completo" required>
      </div>
      <div>
        <label class="label">E-mail</label>
        <input type="email" name="user[email]" class="input-field" placeholder="email@exemplo.com" required>
      </div>
      <%= render "shared/modal_actions", label: "Cadastrar" %>
    <% end %>
  </div>
</dialog>

</div><%# /data-controller="book-slot" %>

<%# ── Modal: Turno reservado (aviso) ─────────────────────────────────────── %>
<dialog id="turno-reservado-modal" onclick="if(event.target===this)this.close()">
  <div class="p-7 text-center">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-4" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="1.5" style="color:#F59E0B">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
    </svg>
    <p class="font-medium mb-6" style="color:#3E2723">Turno Reservado</p>
    <button type="button" onclick="this.closest('dialog').close()" class="btn-primary w-full cursor-pointer">
      Entendi
    </button>
  </div>
</dialog>

<%# ── Modal: Adicionar turno ─────────────────────────────────────────────── %>
<%= render layout: "shared/modal", locals: { id: "add-turno-modal", title: "+ Adicionar turno" } do %>
  <%= form_with url: admin_availabilities_path, method: :post, data: { turbo: false }, class: "flex flex-col gap-4" do %>
    <%= hidden_field_tag "availability[date]", @date %>
    <div>
      <label class="label">Período</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <select name="availability[period]"
                class="w-full bg-transparent border-none outline-none py-3 text-sm cursor-pointer"
                style="color: #3E2723"
                onchange="
                  const presets = {
                    morning:   ['07:00','12:00'],
                    afternoon: ['13:00','18:00'],
                    night:     ['18:00','23:00'],
                    avulsa:    ['13:00','14:00']
                  };
                  const p = presets[this.value];
                  if (p) {
                    this.closest('form').querySelector('[name=\'availability[starts_at]\']').value = p[0];
                    this.closest('form').querySelector('[name=\'availability[ends_at]\']').value = p[1];
                  }
                ">
          <option value="">Selecione um período</option>
          <option value="morning">Turno Manhã (07:00–12:00)</option>
          <option value="afternoon">Turno Tarde (13:00–18:00)</option>
          <option value="night">Turno Noite (18:00–23:00)</option>
          <option value="avulsa">Hora Avulsa (13:00–14:00)</option>
        </select>
      </div>
    </div>
    <div>
      <label class="label">Início e Fim</label>
      <div class="flex items-center gap-2">
        <div class="bg-[#fef8e1] rounded-2xl px-4 py-1 flex-1">
          <input type="time" name="availability[starts_at]" value="07:00"
                 class="w-full bg-transparent border-none outline-none py-3 text-sm"
                 style="color: #3E2723" required>
        </div>
        <span class="text-sm" style="color:#8D6E63">-</span>
        <div class="bg-[#fef8e1] rounded-2xl px-4 py-1 flex-1">
          <input type="time" name="availability[ends_at]" value="12:00"
                 class="w-full bg-transparent border-none outline-none py-3 text-sm"
                 style="color: #3E2723" required>
        </div>
      </div>
    </div>
    <div>
      <label class="label">Valor</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <input type="number" name="availability[price]" step="0.01" min="0"
               placeholder="R$ 0,00"
               class="w-full bg-transparent border-none outline-none py-3 text-sm"
               style="color: #3E2723" required>
      </div>
    </div>
    <%= render "shared/modal_actions", label: "Salvar" %>
  <% end %>
<% end %>

<%# ── Modais por turno: Editar + Excluir ─────────────────────────────────── %>
<% @availabilities.reject(&:booked?).each do |av| %>
  <%= render layout: "shared/modal", locals: { id: "edit-av-#{av.id}", title: "Editar turno" } do %>
    <%= form_with url: admin_availability_path(av), method: :patch, data: { turbo: false }, class: "flex flex-col gap-4" do %>
      <div>
        <label class="label">Período</label>
        <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
          <select class="w-full bg-transparent border-none outline-none py-3 text-sm cursor-pointer"
                  style="color: #3E2723">
            <option value=""><%= av.label %></option>
            <option value="morning">Turno Manhã (07:00–12:00)</option>
            <option value="afternoon">Turno Tarde (13:00–18:00)</option>
            <option value="night">Turno Noite (18:00–23:00)</option>
            <option value="avulsa">Hora Avulsa</option>
          </select>
        </div>
      </div>
      <div>
        <label class="label">Início e Fim</label>
        <div class="flex items-center gap-2">
          <div class="bg-[#fef8e1] rounded-2xl px-4 py-1 flex-1">
            <input type="time" name="availability[starts_at]"
                   value="<%= av.starts_at.strftime('%H:%M') %>"
                   class="w-full bg-transparent border-none outline-none py-3 text-sm"
                   style="color: #3E2723" required>
          </div>
          <span class="text-sm" style="color:#8D6E63">-</span>
          <div class="bg-[#fef8e1] rounded-2xl px-4 py-1 flex-1">
            <input type="time" name="availability[ends_at]"
                   value="<%= av.ends_at.strftime('%H:%M') %>"
                   class="w-full bg-transparent border-none outline-none py-3 text-sm"
                   style="color: #3E2723" required>
          </div>
        </div>
      </div>
      <div>
        <label class="label">Valor</label>
        <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
          <input type="number" name="availability[price]" step="0.01" min="0" required
                 value="<%= av.price %>"
                 class="w-full bg-transparent border-none outline-none py-3 text-sm"
                 style="color: #3E2723">
        </div>
      </div>
      <%= render "shared/modal_actions", label: "Salvar alterações" %>
    <% end %>
  <% end %>

  <%= render layout: "shared/modal", locals: { id: "delete-av-#{av.id}", title: "" } do %>
    <p class="text-center text-base font-medium mb-2" style="color: #3E2723">
      Tem certeza que deseja excluir esse item?
    </p>
    <div class="flex gap-3 mt-5">
      <button type="button" onclick="this.closest('dialog').close()" class="btn-outline flex-1 cursor-pointer">
        Cancelar
      </button>
      <%= button_to "Excluir", admin_availability_path(av), method: :delete,
            class: "btn-primary flex-1 cursor-pointer" %>
    </div>
  <% end %>
<% end %>
