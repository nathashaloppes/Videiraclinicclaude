<% content_for :title, "Turnos padrão" %>

<div class="flex items-center gap-2 mb-1 h-10">
  <%= link_to admin_availabilities_path, class: "shrink-0 p-2 -ml-2 hover:bg-white/50 rounded-full inline-block" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" style="color: #5D4037"
         fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
    </svg>
  <% end %>
  <h1 class="text-xl font-medium" style="color: #5D4037">Turnos padrão</h1>
  <button type="button" onclick="<%= open_modal('add-template-modal') %>"
          class="ml-auto btn-sm-primary cursor-pointer flex items-center gap-1">
    + Adicionar
  </button>
</div>

<p class="text-sm mb-5" style="color: #8D6E63">
  Defina os turnos uma vez — eles são criados automaticamente todos os dias
  (próximos 90 dias). Para bloquear um dia específico, use a tela de
  <%= link_to "Turnos", admin_availabilities_path, class: "underline", style: "color: #5D4037" %>.
</p>

<% if @templates.empty? %>
  <div class="empty-state"><p>Nenhum turno padrão cadastrado.</p></div>
<% else %>
  <div class="flex flex-col gap-3">
    <% @templates.each do |t| %>
      <div class="bg-white rounded-2xl shadow-sm p-4 flex items-center gap-3 <%= 'opacity-50' unless t.active? %>">

        <%# Toggle ativar/pausar %>
        <%= button_to toggle_admin_shift_template_path(t), method: :patch,
              class: "shrink-0 inline-flex h-6 w-11 items-center rounded-full transition-colors",
              style: "background-color: #{t.active? ? '#5D4037' : '#E0E0E0'}" do %>
          <span class="inline-block h-4 w-4 rounded-full bg-white shadow transition-transform"
                style="margin-left:<%= t.active? ? '18px' : '4px' %>"></span>
        <% end %>

        <div class="flex-1 min-w-0">
          <p class="font-medium text-sm" style="color: #3E2723"><%= t.label %></p>
          <p class="text-xs mt-0.5" style="color: #8D6E63">
            (<%= t.starts_at.strftime("%H:%M") %> às <%= t.ends_at.strftime("%H:%M") %>)
          </p>
          <p class="text-sm font-medium mt-1" style="color: #5D4037">R$ <%= money(t.price_cents) %></p>
        </div>

        <button type="button" onclick="<%= open_modal("delete-template-#{t.id}") %>"
                class="p-2 rounded-full hover:bg-[#FFEBEE] transition-colors cursor-pointer shrink-0"
                aria-label="Excluir turno padrão">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2" style="color:#d4183d">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        </button>
      </div>
    <% end %>
  </div>
<% end %>

<%# ── Modal: Adicionar turno padrão ───────────────────────────────────────── %>
<%= render layout: "shared/modal", locals: { id: "add-template-modal", title: "Adicionar turno padrão" } do %>
  <%= form_with url: admin_shift_templates_path, method: :post, data: { turbo: false }, class: "flex flex-col gap-4" do %>
    <div>
      <label class="label">Período</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <select name="shift_template[period]"
                class="w-full bg-transparent border-none outline-none py-3 text-sm cursor-pointer"
                style="color: #3E2723"
                onchange="
                  const presets = {
                    dawn:      ['00:00','04:00'],
                    morning:   ['07:00','12:00'],
                    afternoon: ['13:00','18:00'],
                    night:     ['18:00','23:00'],
                    avulsa:    ['13:00','14:00']
                  };
                  const p = presets[this.value];
                  if (p) {
                    this.closest('form').querySelector('[name=\'shift_template[starts_at]\']').value = p[0];
                    this.closest('form').querySelector('[name=\'shift_template[ends_at]\']').value = p[1];
                  }
                ">
          <option value="">Selecione um período</option>
          <option value="morning">Turno Manhã</option>
          <option value="afternoon">Turno Tarde</option>
          <option value="night">Turno Noite</option>
          <option value="dawn">Turno Madrugada</option>
          <option value="avulsa">Hora Avulsa</option>
        </select>
      </div>
    </div>
    <div>
      <label class="label">Início e Fim</label>
      <div class="flex items-center gap-2">
        <div class="bg-[#fef8e1] rounded-2xl px-4 py-1 flex-1">
          <input type="time" name="shift_template[starts_at]" value="07:00"
                 class="w-full bg-transparent border-none outline-none py-3 text-sm"
                 style="color: #3E2723" required>
        </div>
        <span class="text-sm" style="color:#8D6E63">-</span>
        <div class="bg-[#fef8e1] rounded-2xl px-4 py-1 flex-1">
          <input type="time" name="shift_template[ends_at]" value="12:00"
                 class="w-full bg-transparent border-none outline-none py-3 text-sm"
                 style="color: #3E2723" required>
        </div>
      </div>
    </div>
    <div>
      <label class="label">Valor</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <input type="text" inputmode="numeric" name="shift_template[price]"
               placeholder="R$ 0,00"
               data-controller="input-mask" data-input-mask-pattern-value="money"
               class="w-full bg-transparent border-none outline-none py-3 text-sm"
               style="color: #3E2723" required>
      </div>
    </div>
    <%= render "shared/modal_actions", label: "Salvar" %>
  <% end %>
<% end %>

<%# ── Modais: Excluir turno padrão ────────────────────────────────────────── %>
<% @templates.each do |t| %>
  <%= render "shared/confirm_modal", id: "delete-template-#{t.id}",
        message: "Excluir este turno padrão?",
        detail: "#{t.label} (#{t.starts_at.strftime('%H:%M')}–#{t.ends_at.strftime('%H:%M')}). Os turnos futuros livres desse horário também serão removidos.",
        confirm_path: admin_shift_template_path(t), confirm_method: :delete,
        confirm_label: "Excluir", danger: true, large: true %>
<% end %>
