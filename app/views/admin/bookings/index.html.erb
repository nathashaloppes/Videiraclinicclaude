<% content_for :title, "Reservas" %>

<% selected_date = params[:date].present? ? Date.parse(params[:date]) : Date.current %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-xl font-medium" style="color: #5D4037">Reservas</h1>
  <button type="button"
          class="flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full bg-white shadow-sm"
          style="color: #5D4037">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="2" style="color:#8D6E63">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
    </svg>
    <%= l(selected_date, format: :long).downcase %>
  </button>
</div>

<%# ── Week strip ─────────────────────────────────────────────────────────── %>
<% week_start = selected_date.beginning_of_week(:sunday) %>
<div class="bg-white rounded-2xl shadow-sm px-2 py-2 mb-5 flex items-center gap-1">
  <%= link_to admin_bookings_path(date: (selected_date - 7).to_s),
        class: "shrink-0 w-7 h-7 flex items-center justify-center rounded-full text-base hover:bg-[#fef8e1]",
        style: "color: #8D6E63" do %>‹<% end %>
  <div class="flex-1 flex justify-between">
    <% 7.times do |i| %>
      <% day = week_start + i %>
      <% active = day == selected_date %>
      <%= link_to admin_bookings_path(date: day.to_s),
            class: "flex flex-col items-center px-2 py-1.5 rounded-2xl transition-all",
            style: active ? "background-color: #5D4037" : "" do %>
        <span class="text-xs font-medium" style="color: <%= active ? '#ffffff' : '#8D6E63' %>">
          <%= %w[DOM SEG TER QUA QUI SEX SÁB][day.wday] %>
        </span>
        <span class="text-xs font-medium" style="color: <%= active ? '#ffffff' : '#5D4037' %>">
          <%= day.day %>
        </span>
      <% end %>
    <% end %>
  </div>
  <%= link_to admin_bookings_path(date: (selected_date + 7).to_s),
        class: "shrink-0 w-7 h-7 flex items-center justify-center rounded-full text-base hover:bg-[#fef8e1]",
        style: "color: #8D6E63" do %>›<% end %>
</div>

<%# ── Lista de reservas ───────────────────────────────────────────────────── %>
<% if @booking_groups.empty? %>
  <div class="empty-state">
    <p>Nenhuma reserva encontrada.</p>
  </div>
<% else %>
  <div class="flex flex-col gap-3">
    <% @booking_groups.each do |group| %>
      <div class="bg-white rounded-2xl shadow-sm p-4">
        <div class="flex items-start gap-3">
          <%= render "shared/avatar", user: group.dentist, size: "md" %>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-sm" style="color: #3E2723"><%= group.dentist.name %></p>
            <p class="text-xs" style="color: #8D6E63"><%= group.dentist.email %></p>
            <% group.bookings.each do |b| %>
              <p class="text-xs mt-1" style="color: #8D6E63">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 inline mr-0.5" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <%= l(b.availability.date, format: "%A, %-d de %B") %>
                , <%= b.availability.starts_at.strftime("%H:%M") %> às <%= b.availability.ends_at.strftime("%H:%M") %>
              </p>
            <% end %>
            <p class="text-sm font-medium mt-1" style="color: #5D4037">
              R$ <%= money(group.total_cents) %>
            </p>
          </div>
          <button type="button" onclick="<%= open_modal("edit-booking-#{group.id}") %>"
                  class="shrink-0 p-1.5 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="1.5" style="color: #8D6E63">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </button>
        </div>
      </div>
    <% end %>
  </div>
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
<% end %>

<%# ── Modais: alterar reserva por grupo ──────────────────────────────────── %>
<% @booking_groups.each do |group| %>
  <%= render layout: "shared/modal", locals: { id: "edit-booking-#{group.id}", title: "Alterar reserva" } do %>
    <div class="flex items-center gap-3 mb-4 pb-3 border-b" style="border-color: #E0E0E0">
      <%= render "shared/avatar", user: group.dentist, size: "sm" %>
      <div>
        <p class="text-sm font-medium" style="color: #3E2723"><%= group.dentist.name %></p>
        <p class="text-xs" style="color: #8D6E63"><%= group.dentist.email %></p>
      </div>
    </div>
    <% if group.pending? || group.confirmed? %>
      <div class="flex flex-col gap-3">
        <div>
          <label class="label">Data</label>
          <div class="bg-[#fef8e1] rounded-2xl px-4 py-1 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2" style="color:#8D6E63">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <input type="text" readonly
                   value="<%= l(group.bookings.first.availability.date, format: :long) %>"
                   class="w-full bg-transparent border-none outline-none py-3 text-sm"
                   style="color: #3E2723">
          </div>
        </div>
        <% group.bookings.each do |b| %>
          <div class="rounded-2xl p-4 border" style="border-color: #E0E0E0">
            <p class="text-xs mb-1" style="color: #8D6E63"><%= b.availability.label %></p>
            <p class="text-xs" style="color: #8D6E63">
              <%= b.availability.starts_at.strftime("%H:%M") %> – <%= b.availability.ends_at.strftime("%H:%M") %>
            </p>
            <p class="text-sm font-medium mt-1" style="color: #5D4037">R$ <%= money(b.price_cents) %></p>
          </div>
        <% end %>
        <button type="button" onclick="this.closest('dialog').close(); document.getElementById('cancel-booking-<%= group.id %>').showModal()"
                class="w-full py-3 rounded-full text-sm font-medium cursor-pointer border"
                style="border-color: #d4183d; color: #d4183d; background: transparent">
          Cancelar reserva
        </button>
      </div>
    <% else %>
      <p class="text-sm text-center" style="color: #8D6E63">
        Esta reserva já foi <%= t("booking_group.status.#{group.status}") %> e não pode ser alterada.
      </p>
      <div class="mt-4">
        <button type="button" onclick="this.closest('dialog').close()"
                class="btn-outline w-full cursor-pointer">Fechar</button>
      </div>
    <% end %>
  <% end %>

  <%# Confirmar cancelamento %>
  <%= render "shared/confirm_modal", id: "cancel-booking-#{group.id}",
        message: "Cancelar reserva?",
        detail: "O valor de R$ #{money(group.total_cents)} será retornado como crédito para o cliente.",
        confirm_path: cancelar_admin_booking_path(group), confirm_method: :patch,
        confirm_label: "Sim, cancelar", danger: true %>
<% end %>
