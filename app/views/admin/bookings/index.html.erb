<% content_for :title, "Reservas" %>

<h1 class="text-2xl font-medium mb-4 text-vdc-primary">Reservas</h1>

<div class="card-sm mb-4">
  <%= form_with url: admin_bookings_path, method: :get, data: { turbo: false }, class: "flex flex-col gap-3" do |f| %>
    <%= f.select :status,
          options_for_select([["Todos os status", ""], ["Pendente", "pending"], ["Confirmado", "confirmed"],
                              ["Cancelado", "cancelled"], ["Expirado", "expired"]], params[:status]),
          {}, class: "input-field" %>
    <%= f.date_field :date, value: params[:date], class: "input-field" %>
    <div class="flex gap-2">
      <%= f.submit "Filtrar", class: "btn-primary flex-1 cursor-pointer" %>
      <%= link_to "Limpar", admin_bookings_path, class: "btn-outline flex-1" %>
    </div>
  <% end %>
</div>

<% if @booking_groups.empty? %>
  <div class="empty-state">
    <p>Nenhuma reserva encontrada.</p>
  </div>
<% else %>
  <div class="flex flex-col gap-3">
    <% @booking_groups.each do |group| %>
      <%= link_to admin_booking_path(group), class: "card-link" do %>
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-mono text-vdc-secondary">#<%= group.id.split("-").first %></span>
          <span class="<%= booking_group_status_badge(group.status) %>">
            <%= t("booking_group.status.#{group.status}") %>
          </span>
        </div>
        <p class="text-sm font-medium mb-1 text-vdc-foreground"><%= group.dentist.name %></p>
        <div class="flex justify-between text-xs text-vdc-secondary">
          <span><%= pluralize(group.bookings.size, "horário", "horários") %> · <%= l(group.created_at, format: :default) %></span>
          <span class="font-medium text-vdc-primary">R$ <%= money(group.total_cents) %></span>
        </div>
      <% end %>
    <% end %>
  </div>
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
<% end %>
