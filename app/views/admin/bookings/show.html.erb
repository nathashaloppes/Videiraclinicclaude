<% content_for :title, "Reserva ##{@booking_group.id.split('-').first}" %>

<div class="mb-4">
  <%= link_to "← Reservas", admin_bookings_path, class: "text-sm text-gray-500 hover:underline" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <%# Dados da reserva %>
  <div class="lg:col-span-2 space-y-5">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-xl font-bold text-gray-900">Reserva</h1>
        <span class="<%= booking_group_status_class(@booking_group.status) %> text-sm font-semibold px-3 py-1 rounded-full">
          <%= @booking_group.status %>
        </span>
      </div>

      <div class="text-sm space-y-2 text-gray-600 mb-5">
        <p><strong>Dentista:</strong> <%= @booking_group.patient.name %> (<%= @booking_group.patient.email %>)</p>
        <p><strong>Criado em:</strong> <%= l(@booking_group.created_at, format: :default) %></p>
      </div>

      <div class="divide-y divide-gray-100">
        <% @booking_group.bookings.includes(:availability => [:service, :dentist]).each do |b| %>
          <div class="py-3 flex justify-between items-start">
            <div>
              <p class="font-medium text-gray-900"><%= b.availability.service.name %></p>
              <p class="text-xs text-gray-500">
                <%= l(b.availability.date, format: :default) %> ·
                <%= b.availability.starts_at.strftime("%H:%M") %>–<%= b.availability.ends_at.strftime("%H:%M") %>
              </p>
              <span class="text-xs <%= b.confirmed? ? 'text-green-600' : 'text-gray-400' %>">
                <%= b.status %>
              </span>
            </div>
            <span class="font-semibold text-sm text-gray-700">R$ <%= money(b.price_cents) %></span>
          </div>
        <% end %>
      </div>

      <div class="border-t pt-4 mt-2 space-y-1 text-sm">
        <div class="flex justify-between text-gray-600">
          <span>Subtotal</span>
          <span>R$ <%= money(@booking_group.subtotal_cents) %></span>
        </div>
        <% if @booking_group.discount_cents > 0 %>
          <div class="flex justify-between text-green-700">
            <span>Desconto</span>
            <span>− R$ <%= money(@booking_group.discount_cents) %></span>
          </div>
        <% end %>
        <div class="flex justify-between font-bold text-base text-gray-900 pt-2 border-t">
          <span>Total</span>
          <span class="text-blue-700">R$ <%= money(@booking_group.total_cents) %></span>
        </div>
      </div>
    </div>

    <%# Pagamento %>
    <% if @booking_group.payment %>
      <% p = @booking_group.payment %>
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="font-semibold text-gray-900 mb-3">Pagamento</h2>
        <div class="text-sm text-gray-600 space-y-1">
          <p><strong>Status:</strong>
            <span class="<%= p.paid? ? 'text-green-600' : 'text-gray-500' %> font-medium">
              <%= p.status %>
            </span>
          </p>
          <p><strong>Gateway ID:</strong> <span class="font-mono text-xs"><%= p.gateway_id %></span></p>
          <% if p.paid_at %><p><strong>Pago em:</strong> <%= l(p.paid_at, format: :default) %></p><% end %>
          <% if p.expires_at %><p><strong>Expirava em:</strong> <%= l(p.expires_at, format: :default) %></p><% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Histórico PaperTrail %>
  <div class="bg-white rounded-xl border border-gray-200 p-6 h-fit">
    <h2 class="font-semibold text-gray-900 mb-4">Histórico de alterações</h2>
    <% if @versions.empty? %>
      <p class="text-sm text-gray-400">Sem alterações registradas.</p>
    <% else %>
      <div class="space-y-3">
        <% @versions.each do |v| %>
          <div class="text-xs border-l-2 border-gray-200 pl-3">
            <p class="font-medium text-gray-700"><%= v.event %></p>
            <p class="text-gray-400"><%= l(v.created_at, format: :default) %></p>
            <p class="text-gray-500">Por: <%= v.whodunnit&.truncate(20) || "sistema" %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
