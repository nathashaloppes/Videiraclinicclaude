<% content_for :title, "Criar conta" %>

<%# Tabs Login / Cadastro %>
<div class="bg-white rounded-2xl shadow-sm flex p-1 mb-6">
  <%= link_to new_user_session_path,
        class: "flex-1 text-center py-2.5 rounded-xl text-sm font-medium",
        style: "color: #8D6E63" do %>
    Login
  <% end %>
  <span class="flex-1 text-center py-2.5 rounded-xl text-sm font-medium text-white"
        style="background-color: #5D4037">
    Cadastro
  </span>
</div>

<%= render "shared/form_errors", object: resource if resource.errors.any? %>

<div class="bg-white rounded-2xl shadow-sm p-5">
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
        html: { class: "flex flex-col gap-4" }) do |f| %>

    <div>
      <label class="label">Nome Completo *</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <%= f.text_field :name, autofocus: true, autocomplete: "name",
              placeholder: "",
              class: "w-full bg-transparent border-none outline-none py-3 text-sm",
              style: "color: #3E2723" %>
      </div>
    </div>

    <div>
      <label class="label">Email *</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <%= f.email_field :email, autocomplete: "email",
              placeholder: "",
              class: "w-full bg-transparent border-none outline-none py-3 text-sm",
              style: "color: #3E2723" %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="label">Telefone *</label>
        <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
          <%= f.telephone_field :phone, autocomplete: "tel",
                placeholder: "(00) 00000-0000",
                class: "w-full bg-transparent border-none outline-none py-3 text-sm",
                style: "color: #3E2723",
                data: { controller: "input-mask", "input-mask-pattern-value": "phone" } %>
        </div>
      </div>
      <div>
        <label class="label">Registro CRO *</label>
        <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
          <%= f.text_field :cro,
                placeholder: "CRO-XX 00000",
                class: "w-full bg-transparent border-none outline-none py-3 text-sm",
                style: "color: #3E2723",
                data: { controller: "input-mask", "input-mask-pattern-value": "cro" } %>
        </div>
      </div>
    </div>

    <div>
      <label class="label">CPF *</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <%= f.text_field :cpf,
              placeholder: "000.000.000-00",
              class: "w-full bg-transparent border-none outline-none py-3 text-sm",
              style: "color: #3E2723",
              data: { controller: "input-mask", "input-mask-pattern-value": "cpf" } %>
      </div>
    </div>

    <div>
      <label class="label">Área de Atuação *</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 py-1">
        <%= f.text_field :specialty,
              placeholder: "Ex: Ortodontia, Implantodontia...",
              class: "w-full bg-transparent border-none outline-none py-3 text-sm",
              style: "color: #3E2723" %>
      </div>
    </div>

    <div>
      <label class="label">Senha *</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 flex items-center"
           data-controller="password-toggle">
        <%= f.password_field :password, autocomplete: "new-password",
              placeholder: "Mínimo 6 caracteres",
              class: "flex-1 bg-transparent border-none outline-none py-3 text-sm",
              style: "color: #3E2723",
              data: { "password-toggle-target": "input" } %>
        <button type="button" class="shrink-0 ml-2"
                data-action="click->password-toggle#toggle" aria-label="Mostrar senha">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2" style="color: #8D6E63">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
        </button>
      </div>
    </div>

    <div>
      <label class="label">Confirmar Senha *</label>
      <div class="bg-[#fef8e1] rounded-2xl px-4 flex items-center"
           data-controller="password-toggle">
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              placeholder: "",
              class: "flex-1 bg-transparent border-none outline-none py-3 text-sm",
              style: "color: #3E2723",
              data: { "password-toggle-target": "input" } %>
        <button type="button" class="shrink-0 ml-2"
                data-action="click->password-toggle#toggle" aria-label="Mostrar confirmação">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2" style="color: #8D6E63">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
        </button>
      </div>
    </div>

    <label class="flex items-start gap-3 text-xs cursor-pointer mt-1" style="color: #8D6E63">
      <%= f.check_box :terms_accepted, required: true,
            class: "mt-0.5 w-4 h-4 rounded shrink-0 accent-[#5D4037]" %>
      <span>
        Aceito os
        <%= link_to "termos de uso e política de privacidade", terms_path,
              target: "_blank", class: "underline", style: "color: #5D4037" %>
      </span>
    </label>

    <%= f.submit "Cadastrar", class: "btn-primary w-full cursor-pointer mt-2" %>

  <% end %>

  <div class="flex items-center gap-3 my-3">
    <div class="flex-1 h-px" style="background-color: #E0E0E0"></div>
    <span class="text-xs" style="color: #8D6E63">ou</span>
    <div class="flex-1 h-px" style="background-color: #E0E0E0"></div>
  </div>

  <%= render "shared/google_button", label: "Cadastrar com Google" %>
</div>
